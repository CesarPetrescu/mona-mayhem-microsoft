---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<style>
			/* ── Default theme tokens ── */
			:root {
				--bg-page: #f4f4f4;
				--bg-container: #ffffff;
				--bg-result: #f9fafb;
				--bg-card: #ffffff;
				--bg-button: #111827;
				--bg-button-disabled: #9ca3af;
				--color-text: #111827;
				--color-muted: #4b5563;
				--color-button: #ffffff;
				--border-color: #d1d5db;
				--font-family: Arial, Helvetica, sans-serif;
				--font-title: inherit;
				--glow-accent: transparent;
				--glow-title: none;
				--border-radius: 6px;
				--container-radius: 10px;
			}

			/* ── Retro arcade blue/orange theme ── */
			:root.theme-retro {
				--bg-page: #0a0a1a;
				--bg-container: #0d0d2b;
				--bg-result: #060614;
				--bg-card: #0f0f30;
				--bg-button: #ff6b35;
				--bg-button-disabled: #7a3318;
				--color-text: #00f5ff;
				--color-muted: #a0e8ef;
				--color-button: #0a0a1a;
				--border-color: #00f5ff;
				--font-family: 'Courier New', Courier, monospace;
				--font-title: 'Courier New', Courier, monospace;
				--glow-accent: #00f5ff;
				--glow-title: 0 0 8px #00f5ff, 0 0 20px #00f5ff66;
				--border-radius: 0px;
				--container-radius: 0px;
			}

			body {
				font-family: var(--font-family);
				margin: 0;
				padding: 1.5rem;
				background: var(--bg-page);
				color: var(--color-text);
				display: grid;
				place-items: center;
				min-height: 100vh;
				transition: background 0.3s, color 0.3s;
			}

			.container {
				width: min(760px, 100%);
				padding: 1.5rem;
				border-radius: var(--container-radius);
				background: var(--bg-container);
				border: 1px solid var(--border-color);
				box-sizing: border-box;
				transition: background 0.3s, border-color 0.3s;
			}

			/* Retro scanline overlay */
			:root.theme-retro .container::before {
				content: '';
				position: fixed;
				inset: 0;
				background: repeating-linear-gradient(
					0deg,
					transparent,
					transparent 2px,
					rgba(0, 245, 255, 0.03) 2px,
					rgba(0, 245, 255, 0.03) 4px
				);
				pointer-events: none;
				z-index: 0;
			}

			:root.theme-retro .container > * {
				position: relative;
				z-index: 1;
			}

			h1 {
				font-size: 1.6rem;
				margin: 0 0 0.75rem;
				font-family: var(--font-title);
				text-shadow: var(--glow-title);
				transition: text-shadow 0.3s;
			}

			p {
				margin: 0 0 1rem;
				color: var(--color-muted);
			}

			form {
				display: grid;
				gap: 0.9rem;
			}

			.field {
				display: grid;
				gap: 0.35rem;
			}

			label {
				font-weight: 600;
				color: var(--color-text);
			}

			input {
				padding: 0.65rem 0.75rem;
				border: 1px solid var(--border-color);
				border-radius: var(--border-radius);
				font-size: 1rem;
				background: var(--bg-card);
				color: var(--color-text);
				font-family: var(--font-family);
				outline: none;
				transition: background 0.3s, border-color 0.3s, color 0.3s;
			}

			:root.theme-retro input:focus {
				box-shadow: 0 0 6px var(--glow-accent);
			}

			button {
				padding: 0.65rem 0.75rem;
				border: 0;
				border-radius: var(--border-radius);
				background: var(--bg-button);
				color: var(--color-button);
				font-weight: 600;
				font-family: var(--font-family);
				cursor: pointer;
				transition: background 0.3s, color 0.3s, box-shadow 0.3s;
			}

			:root.theme-retro button:not(:disabled):hover {
				box-shadow: 0 0 10px #ff6b35aa;
			}

			button:disabled {
				background: var(--bg-button-disabled);
				cursor: not-allowed;
			}

			#battle-result {
				margin-top: 1rem;
				padding: 0.75rem;
				border: 1px solid var(--border-color);
				background: var(--bg-result);
				border-radius: var(--border-radius);
				transition: background 0.3s, border-color 0.3s;
			}

			#status {
				margin-bottom: 0.75rem;
				font-weight: 600;
			}

			.card {
				border: 1px solid var(--border-color);
				border-radius: var(--border-radius);
				padding: 0.75rem;
				margin-top: 0.6rem;
				background: var(--bg-card);
				transition: background 0.3s, border-color 0.3s;
			}

			:root.theme-retro .card {
				border-left: 3px solid #ff6b35;
			}

			.card h2 {
				margin: 0 0 0.35rem;
				font-size: 1rem;
			}

			.name {
				font-weight: 700;
				display: inline-block;
				margin-right: 0.5rem;
			}

			:root.theme-retro .name {
				color: #ff6b35;
				text-shadow: 0 0 6px #ff6b3588;
			}

			.small {
				color: var(--color-muted);
				font-size: 0.92rem;
			}

			/* ── Theme toggle button ── */
			.theme-toggle {
				position: fixed;
				top: 1rem;
				right: 1rem;
				padding: 0.4rem 0.8rem;
				font-size: 0.8rem;
				border: 1px solid var(--border-color);
				border-radius: 999px;
				background: var(--bg-container);
				color: var(--color-text);
				font-family: var(--font-family);
				cursor: pointer;
				z-index: 100;
				transition: background 0.3s, color 0.3s, border-color 0.3s, box-shadow 0.3s;
			}

			:root.theme-retro .theme-toggle {
				box-shadow: 0 0 8px var(--glow-accent);
			}
		</style>
	</head>
	<body>
		<button class="theme-toggle" id="theme-toggle" aria-label="Switch to retro arcade theme" title="Switch to retro arcade theme">🎮 Retro</button>

		<main class="container">
			<h1>Mona Mayhem - GitHub Contribution Battle Arena</h1>
			<p>Enter two GitHub usernames and start a quick contribution battle.</p>

			<form id="battle-form">
				<div class="field">
					<label for="player1">Player 1</label>
					<input id="player1" name="player1" placeholder="e.g. octocat" autocomplete="off" />
				</div>
				<div class="field">
					<label for="player2">Player 2</label>
					<input id="player2" name="player2" placeholder="e.g. mona" autocomplete="off" />
				</div>
				<button id="battle-btn" type="submit">Battle</button>
			</form>

			<section id="battle-result" aria-live="polite">
				<div id="status" class="small"></div>
				<div id="cards"></div>
				<div id="result" class="small"></div>
			</section>
		</main>

		<script type="module">
			// ── Theme toggle ──
			const THEME_KEY = 'mona-mayhem-theme';
			const themeToggleBtn = document.querySelector('#theme-toggle');
			const root = document.documentElement;

			function applyTheme(theme) {
				if (theme === 'retro') {
					root.classList.add('theme-retro');
					themeToggleBtn.textContent = '☀️ Default';
					themeToggleBtn.setAttribute('aria-label', 'Switch to default theme');
					themeToggleBtn.title = 'Switch to default theme';
				} else {
					root.classList.remove('theme-retro');
					themeToggleBtn.textContent = '🎮 Retro';
					themeToggleBtn.setAttribute('aria-label', 'Switch to retro arcade theme');
					themeToggleBtn.title = 'Switch to retro arcade theme';
				}
			}

			// Restore saved preference
			applyTheme(localStorage.getItem(THEME_KEY) || 'default');

			themeToggleBtn.addEventListener('click', () => {
				const next = root.classList.contains('theme-retro') ? 'default' : 'retro';
				localStorage.setItem(THEME_KEY, next);
				applyTheme(next);
			});
		</script>

		<script type="module">
			const USERNAME_RE = /^(?!-)(?!.*--)[a-z0-9](?:[a-z0-9-]{0,37}[a-z0-9])?$/i;

			const form = document.querySelector('#battle-form');
			const button = document.querySelector('#battle-btn');
			const statusEl = document.querySelector('#status');
			const cardsEl = document.querySelector('#cards');
			const resultEl = document.querySelector('#result');

			const playerInput1 = document.querySelector('#player1');
			const playerInput2 = document.querySelector('#player2');

			function setStatus(message) {
				statusEl.textContent = message;
			}

			function normalize(name) {
				return (name || '').trim().toLowerCase();
			}

			function isValidUsername(name) {
				return Boolean(name) && name.length <= 39 && USERNAME_RE.test(name);
			}

			function scoreFromPayload(payload) {
				const raw = payload?.data;
				if (!raw || typeof raw !== 'object') return 0;
				return Number(raw.total_contributions || 0);
			}

			function cardFor(playerName, data, error) {
				const total = error ? 'Unavailable' : `${data.total} contributions`;
				return `
					<div class="card">
						<h2><span class="name">${playerName}</span> <span class="small">${error ? 'Error' : 'Ready'}</span></h2>
						<div class="small">Total contributions: ${total}</div>
						<div class="small">Cache status: ${error ? 'failed' : data.cacheStatus}</div>
						<div class="small">Source: ${data.source}</div>
					</div>
				`;
			}

			async function fetchPlayer(username) {
				const response = await fetch(`/api/contributions/${encodeURIComponent(username)}`);
				const payload = await response.json();
				if (!response.ok) {
					const message = payload?.error?.message || `Request failed (${response.status})`;
					throw new Error(message);
				}
				return {
					username,
					total: scoreFromPayload(payload),
					cacheStatus: payload.cacheStatus || 'unknown',
					source: payload.source || `https://github.com/${encodeURIComponent(username)}.contribs`,
				};
			}

			function render(players) {
				cardsEl.innerHTML = players.map((player) => {
					if (player.error) {
						return cardFor(player.username, { total: 0, cacheStatus: 'error', source: player.source }, true);
					}
					return cardFor(player.username, player, false);
				}).join('');
			}

			function renderResult(players) {
				const valid = players.filter((p) => !p.error);
				if (valid.length < 2) {
					if (valid.length === 1) {
						resultEl.textContent = `${valid[0].username} wins by default; other player did not load.`;
						return;
					}
					resultEl.textContent = 'No valid players loaded. Fix input and try again.';
					return;
				}

				const [a, b] = valid;
				if (a.total === b.total) {
					resultEl.textContent = `It's a tie at ${a.total} contributions each.`;
					return;
				}

				const winner = a.total > b.total ? a : b;
				resultEl.textContent = `${winner.username} wins with ${winner.total} contributions.`;
			}

			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				resultEl.textContent = '';
				cardsEl.innerHTML = '';

				const player1 = normalize(playerInput1.value);
				const player2 = normalize(playerInput2.value);

				if (!isValidUsername(player1) || !isValidUsername(player2)) {
					setStatus('Both usernames must be valid GitHub usernames.');
					button.disabled = false;
					return;
				}

				setStatus('Fetching contribution data...');
				button.disabled = true;
				button.textContent = 'Battling...';

				const players = [
					{ username: player1 },
					{ username: player2 },
				];

				const results = await Promise.allSettled(players.map((player) => fetchPlayer(player.username)));
				const loaded = results.map((result, index) => {
					if (result.status === 'fulfilled') {
						return result.value;
					}

					return {
						username: players[index].username,
						error: true,
						total: 0,
						cacheStatus: 'error',
						source: `/api/contributions/${encodeURIComponent(players[index].username)}`,
					};
				});

				render(loaded);
				renderResult(loaded);
				setStatus('Battle complete.');
				button.disabled = false;
				button.textContent = 'Battle';
			});
		</script>
	</body>
</html>
