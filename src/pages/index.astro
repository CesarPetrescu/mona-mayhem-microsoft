<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<style is:global>
			/* ── CSS Custom Properties / Themes ─────────────────────────── */
			:root {
				--bg: #0a0a1a;
				--bg-card: #111128;
				--bg-card-border: #2a2a4a;
				--text: #e0e0e0;
				--text-muted: #8888aa;
				--accent-1: #5fed83;
				--accent-2: #8a2be2;
				--accent-error: #ff3366;
				--font-retro: 'Press Start 2P', monospace;
				--glow-1: 0 0 10px var(--accent-1), 0 0 20px var(--accent-1), 0 0 40px var(--accent-1);
				--glow-2: 0 0 10px var(--accent-2), 0 0 20px var(--accent-2), 0 0 40px var(--accent-2);
				--glow-error: 0 0 10px var(--accent-error), 0 0 20px var(--accent-error);
			}

			[data-theme="blue-orange"] {
				--accent-1: #00f5ff;
				--accent-2: #ff6b35;
				--glow-1: 0 0 10px var(--accent-1), 0 0 20px var(--accent-1), 0 0 40px var(--accent-1);
				--glow-2: 0 0 10px var(--accent-2), 0 0 20px var(--accent-2), 0 0 40px var(--accent-2);
			}

			/* ── Keyframe Animations ───────────────────────────────────── */
			@keyframes neonPulse {
				0%, 100% { text-shadow: 0 0 10px var(--accent-1), 0 0 20px var(--accent-1), 0 0 40px var(--accent-1), 0 0 80px var(--accent-1); }
				50% { text-shadow: 0 0 5px var(--accent-1), 0 0 10px var(--accent-1), 0 0 20px var(--accent-1); }
			}

			@keyframes gradientShift {
				0% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
				100% { background-position: 0% 50%; }
			}

			@keyframes shimmer {
				0% { transform: translateX(-100%) rotate(25deg); }
				100% { transform: translateX(200%) rotate(25deg); }
			}

			@keyframes floatIn {
				from { opacity: 0; transform: translateY(20px); }
				to { opacity: 1; transform: translateY(0); }
			}

			@keyframes colorShift {
				0%, 100% { color: var(--accent-1); }
				50% { color: var(--accent-2); }
			}

			@keyframes shake {
				0%, 100% { transform: translateX(0); }
				10%, 50%, 90% { transform: translateX(-4px); }
				30%, 70% { transform: translateX(4px); }
			}

			@keyframes bannerPop {
				0% { transform: scale(0); opacity: 0; }
				60% { transform: scale(1.15); }
				100% { transform: scale(1); opacity: 1; }
			}

			@keyframes bannerGlow {
				0%, 100% { text-shadow: var(--glow-1); }
				50% { text-shadow: var(--glow-2); }
			}

			@keyframes slideInLeft {
				from { opacity: 0; transform: translateX(-40px); }
				to { opacity: 1; transform: translateX(0); }
			}

			@keyframes slideInRight {
				from { opacity: 0; transform: translateX(40px); }
				to { opacity: 1; transform: translateX(0); }
			}

			@keyframes countdownPulse {
				0% { transform: scale(0.5); opacity: 0; }
				50% { transform: scale(1.2); opacity: 1; }
				100% { transform: scale(1); opacity: 0.8; }
			}

			@keyframes skeleton-loading {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}

			/* ── CRT Monitor Frame ─────────────────────────────────────── */
			.crt-monitor {
				position: relative;
				background: #1a1a1a;
				border-radius: 24px;
				padding: 22px 22px 12px;
				box-shadow:
					0 0 0 3px #0d0d0d,
					0 0 0 6px #2a2a2a,
					0 8px 40px rgba(0, 0, 0, 0.8),
					inset 0 2px 4px rgba(255, 255, 255, 0.05);
				max-width: 960px;
				width: 100%;
			}

			/* Monitor brand label */
			.crt-brand {
				text-align: center;
				font-family: var(--font-retro);
				font-size: 0.4rem;
				color: #555;
				letter-spacing: 4px;
				text-transform: uppercase;
				padding: 8px 0 4px;
			}

			.crt-led {
				display: inline-block;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent-1);
				box-shadow: 0 0 6px var(--accent-1);
				margin-left: 8px;
				vertical-align: middle;
				animation: neonPulse 3s ease-in-out infinite;
			}

			/* The curved glass screen */
			.crt-screen {
				position: relative;
				border-radius: 16px / 18px;
				overflow: hidden;
				background: var(--bg);
			}

			/* Scanlines */
			.crt-screen::before {
				content: '';
				position: absolute;
				inset: 0;
				background: repeating-linear-gradient(
					0deg,
					transparent,
					transparent 2px,
					rgba(0, 0, 0, 0.06) 2px,
					rgba(0, 0, 0, 0.06) 4px
				);
				pointer-events: none;
				z-index: 9998;
				border-radius: inherit;
			}

			/* Vignette + lens curvature darkening at edges */
			.crt-screen::after {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(
					ellipse 85% 80% at 50% 50%,
					transparent 55%,
					rgba(0, 0, 0, 0.35) 80%,
					rgba(0, 0, 0, 0.7) 100%
				);
				pointer-events: none;
				z-index: 9999;
				border-radius: inherit;
			}

			/* Chromatic aberration overlay */
			.crt-aberration {
				position: absolute;
				inset: 0;
				pointer-events: none;
				z-index: 9997;
				border-radius: inherit;
				/* Red shift left edge, cyan shift right edge */
				box-shadow:
					inset 3px 0 8px -4px rgba(255, 0, 50, 0.15),
					inset -3px 0 8px -4px rgba(0, 200, 255, 0.15),
					inset 0 3px 8px -4px rgba(255, 0, 50, 0.08),
					inset 0 -3px 8px -4px rgba(0, 200, 255, 0.08);
			}

			/* Glass reflection glare */
			.crt-glare {
				position: absolute;
				top: 5%;
				left: 10%;
				width: 35%;
				height: 25%;
				background: linear-gradient(
					135deg,
					rgba(255, 255, 255, 0.06) 0%,
					rgba(255, 255, 255, 0.02) 40%,
					transparent 100%
				);
				border-radius: 50%;
				pointer-events: none;
				z-index: 9999;
				filter: blur(8px);
			}

			/* RGB sub-pixel texture (very subtle) */
			.crt-rgb {
				position: absolute;
				inset: 0;
				background: repeating-linear-gradient(
					90deg,
					rgba(255, 0, 0, 0.015) 0px,
					rgba(0, 255, 0, 0.015) 1px,
					rgba(0, 100, 255, 0.015) 2px,
					transparent 3px
				);
				pointer-events: none;
				z-index: 9997;
				border-radius: inherit;
			}

			/* Screen flicker */
			@keyframes crtFlicker {
				0%, 100% { opacity: 1; }
				92% { opacity: 1; }
				93% { opacity: 0.97; }
				94% { opacity: 1; }
			}

			.crt-screen > .container {
				animation: crtFlicker 8s linear infinite;
			}

			/* ── Base Styles ───────────────────────────────────────────── */
			* { box-sizing: border-box; }

			body {
				font-family: var(--font-retro);
				margin: 0;
				padding: 2rem 1rem;
				background: #050510;
				color: var(--text);
				display: grid;
				place-items: center;
				min-height: 100vh;
				line-height: 1.8;
			}

			.container {
				width: 100%;
				padding: 1.5rem;
				background: var(--bg);
				position: relative;
			}

			/* ── Controls Bar ──────────────────────────────────────────── */
			.controls {
				display: flex;
				justify-content: flex-end;
				gap: 0.5rem;
				margin-bottom: 0.75rem;
			}

			.control-btn {
				padding: 0.3rem 0.6rem;
				border: 1px solid var(--bg-card-border);
				border-radius: 4px;
				background: transparent;
				color: var(--text-muted);
				font-family: var(--font-retro);
				font-size: 0.5rem;
				cursor: pointer;
				transition: color 0.2s, border-color 0.2s;
			}

			.control-btn:hover {
				color: var(--accent-1);
				border-color: var(--accent-1);
			}

			/* ── Title ─────────────────────────────────────────────────── */
			h1 {
				font-size: 1.1rem;
				margin: 0 0 0.5rem;
				color: var(--accent-1);
				animation: neonPulse 3s ease-in-out infinite;
				text-align: center;
			}

			.subtitle {
				margin: 0 0 1rem;
				color: var(--text-muted);
				font-size: 0.55rem;
				text-align: center;
			}

			/* ── Form ──────────────────────────────────────────────────── */
			form {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				gap: 0.9rem;
				align-items: end;
			}

			form.shake {
				animation: shake 0.5s ease-in-out;
			}

			.field {
				display: grid;
				gap: 0.35rem;
				animation: floatIn 0.6s ease-out both;
			}

			.field:nth-child(1) { animation-delay: 0.1s; }
			.field:nth-child(3) { animation-delay: 0.3s; }

			label {
				font-weight: 600;
				font-size: 0.55rem;
				color: var(--accent-2);
			}

			input {
				padding: 0.65rem 0.75rem;
				border: 1px solid var(--bg-card-border);
				border-radius: 6px;
				font-size: 0.7rem;
				font-family: var(--font-retro);
				background: var(--bg);
				color: var(--text);
				transition: border-color 0.2s, box-shadow 0.2s;
			}

			input:focus {
				outline: none;
				border-color: var(--accent-1);
				box-shadow: 0 0 8px rgba(95, 237, 131, 0.3);
			}

			input.input-error {
				border-color: var(--accent-error);
				box-shadow: 0 0 8px rgba(255, 51, 102, 0.3);
			}

			.error-msg {
				color: var(--accent-error);
				font-size: 0.45rem;
				text-shadow: 0 0 6px rgba(255, 51, 102, 0.4);
				min-height: 1.2em;
			}

			/* ── VS Badge ──────────────────────────────────────────────── */
			.vs-badge {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 50px;
				height: 50px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent-1), var(--accent-2), var(--accent-1));
				background-size: 200% 200%;
				animation: gradientShift 3s ease infinite;
				color: #fff;
				font-weight: 800;
				font-size: 0.7rem;
				align-self: center;
				box-shadow: 0 0 15px rgba(95, 237, 131, 0.3), 0 0 15px rgba(138, 43, 226, 0.3);
				font-family: var(--font-retro);
			}

			/* ── Battle Button ─────────────────────────────────────────── */
			#battle-btn {
				grid-column: 1 / -1;
				padding: 0.75rem 1.25rem;
				border: 2px solid var(--accent-1);
				border-radius: 6px;
				background: transparent;
				color: var(--accent-1);
				font-weight: 600;
				font-family: var(--font-retro);
				font-size: 0.7rem;
				cursor: pointer;
				transition: background 0.2s, box-shadow 0.2s, color 0.2s;
				text-transform: uppercase;
				letter-spacing: 2px;
			}

			#battle-btn:hover:not(:disabled) {
				background: var(--accent-1);
				color: var(--bg);
				box-shadow: var(--glow-1);
			}

			#battle-btn:disabled {
				border-color: var(--text-muted);
				color: var(--text-muted);
				cursor: not-allowed;
			}

			/* ── Focus Visible ─────────────────────────────────────────── */
			*:focus-visible {
				outline: 2px solid var(--accent-1);
				outline-offset: 2px;
				box-shadow: 0 0 8px rgba(95, 237, 131, 0.4);
			}

			input:focus-visible {
				outline: none;
				border-color: var(--accent-1);
				box-shadow: 0 0 8px rgba(95, 237, 131, 0.4);
			}

			/* ── Status ────────────────────────────────────────────────── */
			#status {
				text-align: center;
				font-size: 0.6rem;
				margin: 1rem 0;
			}

			#status.loading {
				animation: colorShift 1.5s ease-in-out infinite;
			}

			/* ── Battle Arena ──────────────────────────────────────────── */
			.battle-arena {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				gap: 1rem;
				align-items: start;
				margin-top: 1rem;
			}

			/* ── Player Cards ──────────────────────────────────────────── */
			.player-card {
				border: 1px solid var(--bg-card-border);
				border-radius: 8px;
				padding: 1rem;
				background: var(--bg-card);
				position: relative;
				overflow: hidden;
				transition: border-color 0.3s;
			}

			.player-card::after {
				content: '';
				position: absolute;
				top: -50%;
				left: -50%;
				width: 30%;
				height: 200%;
				background: linear-gradient(
					90deg,
					transparent,
					rgba(255, 255, 255, 0.05),
					transparent
				);
				transform: rotate(25deg);
				animation: shimmer 4s ease-in-out infinite;
				pointer-events: none;
			}

			.player-card.winner {
				border-color: var(--accent-1);
				box-shadow: 0 0 15px rgba(95, 237, 131, 0.2);
			}

			.player-card.loser { opacity: 0.6; }

			.player-card.card-error {
				border-color: var(--accent-error);
			}

			.player-card.slide-left {
				animation: slideInLeft 0.5s ease-out both;
			}

			.player-card.slide-right {
				animation: slideInRight 0.5s ease-out both;
			}

			.player-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.5rem;
			}

			.player-name {
				font-weight: 700;
				font-size: 0.65rem;
				color: var(--accent-2);
			}

			.player-total {
				font-size: 0.7rem;
				font-weight: 700;
				color: var(--accent-1);
			}

			.player-date-range {
				color: var(--text-muted);
				font-size: 0.45rem;
				margin-bottom: 0.5rem;
			}

			.player-streak {
				color: var(--accent-2);
				font-size: 0.45rem;
				margin-top: 0.5rem;
			}

			/* ── Contribution Grid ─────────────────────────────────────── */
			.contrib-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				grid-template-rows: repeat(7, 1fr);
				gap: 2px;
				width: 100%;
				aspect-ratio: 53 / 7;
			}

			.contrib-cell {
				border-radius: 2px;
				position: relative;
				cursor: default;
				transition: box-shadow 0.2s;
			}

			.contrib-cell:hover {
				box-shadow: 0 0 6px currentColor;
				z-index: 2;
			}

			.contrib-cell[data-count]::before {
				content: attr(data-count) " contributions";
				position: absolute;
				bottom: calc(100% + 4px);
				left: 50%;
				transform: translateX(-50%);
				background: #1a1a3a;
				color: var(--text);
				padding: 4px 8px;
				border-radius: 4px;
				font-size: 0.4rem;
				white-space: nowrap;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.15s;
				z-index: 10;
				border: 1px solid var(--bg-card-border);
			}

			.contrib-cell:hover::before { opacity: 1; }

			/* ── Contribution Legend ────────────────────────────────────── */
			.contrib-legend {
				display: flex;
				align-items: center;
				gap: 4px;
				margin-top: 0.5rem;
				font-size: 0.4rem;
				color: var(--text-muted);
			}

			.legend-square {
				width: 10px;
				height: 10px;
				border-radius: 2px;
			}

			/* ── Skeleton Loading ──────────────────────────────────────── */
			.skeleton {
				background: linear-gradient(90deg, #1a1a3a 25%, #252550 50%, #1a1a3a 75%);
				background-size: 200% 100%;
				animation: skeleton-loading 1.5s infinite;
			}

			.skeleton-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				grid-template-rows: repeat(7, 1fr);
				gap: 2px;
				width: 100%;
				aspect-ratio: 53 / 7;
			}

			.skeleton-cell {
				background: #1a1a3a;
				border-radius: 2px;
			}

			.skeleton-text {
				height: 0.8rem;
				border-radius: 4px;
				margin-bottom: 0.5rem;
			}

			.skeleton-text.short { width: 40%; }
			.skeleton-text.medium { width: 60%; }

			/* ── Winner Banner ─────────────────────────────────────────── */
			#winner-banner {
				text-align: center;
				font-size: 0.8rem;
				padding: 1rem;
				margin-top: 1rem;
				border: 1px solid var(--bg-card-border);
				border-radius: 8px;
				background: var(--bg);
				animation: bannerPop 0.6s ease-out both;
			}

			#winner-banner .banner-text {
				animation: bannerGlow 2s ease-in-out infinite;
			}

			/* ── Countdown Overlay ─────────────────────────────────────── */
			#countdown-overlay {
				position: fixed;
				inset: 0;
				background: rgba(10, 10, 26, 0.92);
				display: flex;
				align-items: center;
				justify-content: center;
				z-index: 10000;
				font-size: 3rem;
				color: var(--accent-1);
				text-shadow: var(--glow-1);
				font-family: var(--font-retro);
			}

			.countdown-number {
				animation: countdownPulse 0.8s ease-out both;
			}

			/* ── Share Button ──────────────────────────────────────────── */
			#share-btn {
				display: block;
				margin: 0.75rem auto 0;
				padding: 0.5rem 1rem;
				border: 1px solid var(--accent-2);
				border-radius: 6px;
				background: transparent;
				color: var(--accent-2);
				font-family: var(--font-retro);
				font-size: 0.5rem;
				cursor: pointer;
				transition: background 0.2s, color 0.2s;
			}

			#share-btn:hover {
				background: var(--accent-2);
				color: #fff;
			}

			.copy-confirm {
				text-align: center;
				color: var(--accent-1);
				font-size: 0.45rem;
				margin-top: 0.3rem;
			}

			/* ── Battle History ─────────────────────────────────────────── */
			.history-section {
				margin-top: 1.5rem;
				border-top: 1px solid var(--bg-card-border);
				padding-top: 1rem;
			}

			.history-title {
				font-size: 0.6rem;
				color: var(--accent-2);
				margin: 0 0 0.75rem;
			}

			.history-entry {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.4rem 0.6rem;
				border: 1px solid var(--bg-card-border);
				border-radius: 4px;
				margin-bottom: 0.3rem;
				font-size: 0.4rem;
				color: var(--text-muted);
				background: var(--bg);
			}

			.history-players { color: var(--text); }
			.history-winner { color: var(--accent-1); }

			#clear-history-btn {
				margin-top: 0.5rem;
				padding: 0.3rem 0.6rem;
				border: 1px solid var(--accent-error);
				border-radius: 4px;
				background: transparent;
				color: var(--accent-error);
				font-family: var(--font-retro);
				font-size: 0.4rem;
				cursor: pointer;
			}

			#clear-history-btn:hover {
				background: var(--accent-error);
				color: #fff;
			}

			/* ── Battle Canvas ─────────────────────────────────────────── */
			#battle-result {
				position: relative;
			}

			#battle-canvas {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 50;
				pointer-events: none;
			}

			.player-card.cracked {
				animation: cardCrack 0.4s ease-out forwards;
				border-color: var(--accent-error) !important;
			}

			@keyframes cardCrack {
				0% { transform: scale(1); filter: brightness(1); }
				30% { transform: scale(0.96) rotate(-1deg); filter: brightness(2.5); }
				60% { transform: scale(0.98) rotate(0.5deg); filter: brightness(0.4); }
				100% { transform: scale(1); filter: brightness(0.5); opacity: 0.5; }
			}

			.player-card.winner-flash {
				animation: winnerFlash 0.6s ease-out forwards;
			}

			@keyframes winnerFlash {
				0% { filter: brightness(1); }
				40% { filter: brightness(2); box-shadow: 0 0 40px var(--accent-1); }
				100% { filter: brightness(1); box-shadow: 0 0 20px rgba(95, 237, 131, 0.3); }
			}

			/* ── Utility ───────────────────────────────────────────────── */
			.hidden { display: none !important; }

			/* ── Responsive: 1024px ────────────────────────────────────── */
			@media (max-width: 1024px) {
				.battle-arena {
					grid-template-columns: 1fr;
					gap: 0.5rem;
				}

				.battle-arena .vs-badge {
					justify-self: center;
				}
			}

			/* ── Responsive: 768px ─────────────────────────────────────── */
			@media (max-width: 768px) {
				body { padding: 0.5rem; }

				.crt-monitor {
					border-radius: 16px;
					padding: 14px 14px 8px;
				}

				.crt-screen { border-radius: 10px / 12px; }

				h1 { font-size: 0.75rem; }
				.subtitle { font-size: 0.45rem; }

				form {
					grid-template-columns: 1fr;
					gap: 0.6rem;
				}

				.vs-badge {
					justify-self: center;
					width: 40px;
					height: 40px;
					font-size: 0.55rem;
				}

				.container { padding: 1rem; }

				label { font-size: 0.45rem; }
				input { font-size: 0.55rem; padding: 0.5rem; }

				#battle-btn { font-size: 0.55rem; padding: 0.6rem; }

				.player-name { font-size: 0.5rem; }
				.player-total { font-size: 0.55rem; }

				#winner-banner { font-size: 0.6rem; }

				.history-entry { font-size: 0.35rem; }
			}
		</style>
	</head>
	<body>
		<div class="crt-monitor">
			<div class="crt-screen">
				<div class="crt-aberration"></div>
				<div class="crt-rgb"></div>
				<div class="crt-glare"></div>
				<main class="container">
					<div class="controls">
						<button id="theme-toggle" class="control-btn" aria-label="Toggle color theme" title="Switch color theme">Theme</button>
						<button id="mute-toggle" class="control-btn" aria-label="Toggle sound" title="Toggle sound effects">Sound: ON</button>
					</div>

					<h1>Mona Mayhem</h1>
					<p class="subtitle">GitHub Contribution Battle Arena</p>

					<form id="battle-form">
						<div class="field">
							<label for="player1">Player 1</label>
							<input id="player1" name="player1" placeholder="e.g. octocat" autocomplete="off" />
							<span id="p1-error" class="error-msg"></span>
						</div>
						<div class="vs-badge">VS</div>
						<div class="field">
							<label for="player2">Player 2</label>
							<input id="player2" name="player2" placeholder="e.g. mona" autocomplete="off" />
							<span id="p2-error" class="error-msg"></span>
						</div>
						<button id="battle-btn" type="submit">Battle!</button>
					</form>

					<section id="battle-result" aria-live="polite">
						<canvas id="battle-canvas" class="hidden"></canvas>
						<div id="status" class="hidden"></div>
						<div id="arena" class="hidden"></div>
						<div id="winner-banner" class="hidden"></div>
						<button id="share-btn" class="hidden">Share Results</button>
						<div id="copy-confirm" class="copy-confirm hidden"></div>
					</section>

					<section id="battle-history" class="history-section hidden">
						<h2 class="history-title">Recent Battles</h2>
						<div id="history-list"></div>
						<button id="clear-history-btn">Clear History</button>
					</section>
				</main>
			</div>
			<div class="crt-brand">Mona Mayhem<span class="crt-led"></span></div>
		</div>

		<div id="countdown-overlay" class="hidden"></div>

		<script type="module">
			// ── Constants ─────────────────────────────────────────────────
			const USERNAME_RE = /^(?!-)(?!.*--)[a-z0-9](?:[a-z0-9-]{0,37}[a-z0-9])?$/i;
			const DEFAULT_COLORS = ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
			const HISTORY_KEY = 'mona-mayhem-history';
			const THEME_KEY = 'mona-mayhem-theme';
			const MUTE_KEY = 'mona-mayhem-mute';
			const MAX_HISTORY = 10;

			// ── DOM Elements ──────────────────────────────────────────────
			const form = document.querySelector('#battle-form');
			const button = document.querySelector('#battle-btn');
			const statusEl = document.querySelector('#status');
			const arenaEl = document.querySelector('#arena');
			const bannerEl = document.querySelector('#winner-banner');
			const shareBtn = document.querySelector('#share-btn');
			const copyConfirm = document.querySelector('#copy-confirm');
			const countdownEl = document.querySelector('#countdown-overlay');
			const historySection = document.querySelector('#battle-history');
			const historyList = document.querySelector('#history-list');
			const clearHistoryBtn = document.querySelector('#clear-history-btn');
			const themeToggle = document.querySelector('#theme-toggle');
			const muteToggle = document.querySelector('#mute-toggle');

			const input1 = document.querySelector('#player1');
			const input2 = document.querySelector('#player2');
			const error1 = document.querySelector('#p1-error');
			const error2 = document.querySelector('#p2-error');

			// ── Theme Toggle ──────────────────────────────────────────────
			function applyTheme(theme) {
				if (theme === 'blue-orange') {
					document.documentElement.setAttribute('data-theme', 'blue-orange');
					themeToggle.textContent = 'Theme: B/O';
				} else {
					document.documentElement.removeAttribute('data-theme');
					themeToggle.textContent = 'Theme: G/P';
				}
			}

			applyTheme(localStorage.getItem(THEME_KEY) || '');

			themeToggle.addEventListener('click', () => {
				const next = document.documentElement.getAttribute('data-theme') === 'blue-orange' ? '' : 'blue-orange';
				localStorage.setItem(THEME_KEY, next);
				applyTheme(next);
			});

			// ── Sound Effects (Web Audio API) ─────────────────────────────
			let audioCtx = null;
			let isMuted = localStorage.getItem(MUTE_KEY) === '1';

			function updateMuteUI() {
				muteToggle.textContent = isMuted ? 'Sound: OFF' : 'Sound: ON';
			}
			updateMuteUI();

			muteToggle.addEventListener('click', () => {
				isMuted = !isMuted;
				localStorage.setItem(MUTE_KEY, isMuted ? '1' : '0');
				updateMuteUI();
			});

			function getAudioCtx() {
				if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
				if (audioCtx.state === 'suspended') audioCtx.resume();
				return audioCtx;
			}

			function playCoinSound() {
				if (isMuted) return;
				const ctx = getAudioCtx();
				const now = ctx.currentTime;

				[440, 880].forEach((freq, i) => {
					const osc = ctx.createOscillator();
					const gain = ctx.createGain();
					osc.type = 'square';
					osc.frequency.value = freq;
					gain.gain.setValueAtTime(0.15, now + i * 0.1);
					gain.gain.exponentialRampToValueAtTime(0.001, now + i * 0.1 + 0.15);
					osc.connect(gain).connect(ctx.destination);
					osc.start(now + i * 0.1);
					osc.stop(now + i * 0.1 + 0.15);
				});
			}

			function playPowerUpSound() {
				if (isMuted) return;
				const ctx = getAudioCtx();
				const now = ctx.currentTime;

				[523, 659, 784, 1047].forEach((freq, i) => {
					const osc = ctx.createOscillator();
					const gain = ctx.createGain();
					osc.type = 'square';
					osc.frequency.value = freq;
					gain.gain.setValueAtTime(0.12, now + i * 0.08);
					gain.gain.exponentialRampToValueAtTime(0.001, now + i * 0.08 + 0.2);
					osc.connect(gain).connect(ctx.destination);
					osc.start(now + i * 0.08);
					osc.stop(now + i * 0.08 + 0.2);
				});
			}

			function playErrorSound() {
				if (isMuted) return;
				const ctx = getAudioCtx();
				const now = ctx.currentTime;

				[300, 200].forEach((freq, i) => {
					const osc = ctx.createOscillator();
					const gain = ctx.createGain();
					osc.type = 'sawtooth';
					osc.frequency.value = freq;
					gain.gain.setValueAtTime(0.15, now + i * 0.15);
					gain.gain.exponentialRampToValueAtTime(0.001, now + i * 0.15 + 0.25);
					osc.connect(gain).connect(ctx.destination);
					osc.start(now + i * 0.15);
					osc.stop(now + i * 0.15 + 0.25);
				});
			}

			// ── Countdown Sequence ────────────────────────────────────────
			function playCountdown() {
				return new Promise((resolve) => {
					const steps = ['3', '2', '1', 'FIGHT!'];
					let i = 0;
					countdownEl.classList.remove('hidden');

					function showNext() {
						if (i >= steps.length) {
							countdownEl.classList.add('hidden');
							countdownEl.innerHTML = '';
							resolve();
							return;
						}
						countdownEl.innerHTML = `<span class="countdown-number" style="color: ${i === 3 ? 'var(--accent-2)' : 'var(--accent-1)'}">${steps[i]}</span>`;
						i++;
						setTimeout(showNext, i <= 3 ? 800 : 600);
					}
					showNext();
				});
			}

			// ── Validation ────────────────────────────────────────────────
			function isValidUsername(name) {
				return Boolean(name) && name.length <= 39 && USERNAME_RE.test(name);
			}

			function normalize(name) {
				return (name || '').trim().toLowerCase();
			}

			function showError(inputEl, errorEl, msg) {
				inputEl.classList.add('input-error');
				errorEl.textContent = msg;
			}

			function clearError(inputEl, errorEl) {
				inputEl.classList.remove('input-error');
				errorEl.textContent = '';
			}

			input1.addEventListener('input', () => clearError(input1, error1));
			input2.addEventListener('input', () => clearError(input2, error2));

			// ── API Fetch ─────────────────────────────────────────────────
			async function fetchPlayer(username) {
				const response = await fetch(`/api/contributions/${encodeURIComponent(username)}`);
				const payload = await response.json();

				if (!response.ok) {
					const message = payload?.error?.message || `Request failed (${response.status})`;
					throw new Error(message);
				}

				const data = payload.data;
				return {
					username,
					total: data.total_contributions || 0,
					from: data.from || '',
					to: data.to || '',
					colors: data.colors_full || DEFAULT_COLORS,
					weeks: data.weeks || [],
				};
			}

			// ── Streak Calculation ────────────────────────────────────────
			function computeStreak(weeks) {
				if (!weeks || !weeks.length) return 0;

				let maxStreak = 0;
				let currentStreak = 0;

				for (const week of weeks) {
					for (const day of week.contribution_days) {
						if (day.count > 0) {
							currentStreak++;
							if (currentStreak > maxStreak) maxStreak = currentStreak;
						} else {
							currentStreak = 0;
						}
					}
				}

				return maxStreak;
			}

			// ── Rendering ─────────────────────────────────────────────────
			function formatDate(dateStr) {
				if (!dateStr) return '';
				return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
			}

			function renderGrid(player) {
				if (!player.weeks || !player.weeks.length) return '';

				const cells = player.weeks.map(week =>
					week.contribution_days.map(day => {
						const color = player.colors[day.level] || player.colors[0];
						return `<div class="contrib-cell" style="background:${color};color:${color}" data-count="${day.count}"></div>`;
					}).join('')
				).join('');

				return `<div class="contrib-grid">${cells}</div>`;
			}

			function renderLegend(colors) {
				if (!colors || !colors.length) return '';
				const squares = colors.map(c => `<div class="legend-square" style="background:${c}"></div>`).join('');
				return `<div class="contrib-legend"><span>Less</span>${squares}<span>More</span></div>`;
			}

			function renderPlayerCard(player, status, slideDir) {
				const classes = ['player-card'];
				if (status) classes.push(status);
				if (slideDir) classes.push(slideDir);

				if (player.error) {
					return `
						<div class="${classes.join(' ')} card-error">
							<div class="player-header">
								<span class="player-name">${player.username}</span>
							</div>
							<div class="error-msg">${player.errorMessage || 'Failed to load'}</div>
						</div>
					`;
				}

				const dateRange = player.from && player.to
					? `${formatDate(player.from)} - ${formatDate(player.to)}`
					: '';
				const streak = computeStreak(player.weeks);

				return `
					<div class="${classes.join(' ')}">
						<div class="player-header">
							<span class="player-name">${player.username}</span>
							<span class="player-total">${player.total.toLocaleString()}</span>
						</div>
						<div class="player-date-range">${dateRange}</div>
						${renderGrid(player)}
						${renderLegend(player.colors)}
						<div class="player-streak">Longest Streak: ${streak} days</div>
					</div>
				`;
			}

			function renderLoadingSkeleton() {
				const cells = Array(53 * 7).fill('<div class="skeleton-cell skeleton"></div>').join('');
				const card = `
					<div class="player-card">
						<div class="skeleton skeleton-text short"></div>
						<div class="skeleton skeleton-text medium"></div>
						<div class="skeleton-grid">${cells}</div>
					</div>
				`;
				arenaEl.innerHTML = `<div class="battle-arena">${card}<div class="vs-badge">VS</div>${card}</div>`;
				arenaEl.classList.remove('hidden');
			}

			function render(players) {
				const [p1, p2] = players;
				const bothValid = !p1.error && !p2.error;

				let p1Status = null;
				let p2Status = null;

				if (bothValid) {
					if (p1.total > p2.total) { p1Status = 'winner'; p2Status = 'loser'; }
					else if (p2.total > p1.total) { p1Status = 'loser'; p2Status = 'winner'; }
				}

				arenaEl.innerHTML = `
					<div class="battle-arena">
						${renderPlayerCard(p1, p1Status, 'slide-left')}
						<div class="vs-badge">VS</div>
						${renderPlayerCard(p2, p2Status, 'slide-right')}
					</div>
				`;
				arenaEl.classList.remove('hidden');
			}

			function renderWinnerBanner(players) {
				const valid = players.filter(p => !p.error);
				bannerEl.classList.remove('hidden');

				if (valid.length < 2) {
					if (valid.length === 1) {
						bannerEl.innerHTML = `<div class="banner-text">${valid[0].username} wins by default!</div>`;
					} else {
						bannerEl.innerHTML = `<div class="banner-text">Both players failed to load!</div>`;
					}
					return;
				}

				const [a, b] = valid;
				if (a.total === b.total) {
					bannerEl.innerHTML = `<div class="banner-text">IT'S A TIE! ${a.total.toLocaleString()} each!</div>`;
				} else {
					const winner = a.total > b.total ? a : b;
					bannerEl.innerHTML = `<div class="banner-text">${winner.username} WINS!</div>`;
				}
			}

			// ── Battle History ─────────────────────────────────────────────
			function getHistory() {
				try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; }
				catch { return []; }
			}

			function saveHistory(entry) {
				const history = getHistory();
				history.unshift(entry);
				if (history.length > MAX_HISTORY) history.length = MAX_HISTORY;
				localStorage.setItem(HISTORY_KEY, JSON.stringify(history));
			}

			function renderHistory() {
				const history = getHistory();
				if (!history.length) {
					historySection.classList.add('hidden');
					return;
				}

				historySection.classList.remove('hidden');
				historyList.innerHTML = history.map(h => {
					const time = new Date(h.time).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
					return `
						<div class="history-entry">
							<span class="history-players">${h.p1.name} (${h.p1.total}) vs ${h.p2.name} (${h.p2.total})</span>
							<span class="history-winner">${h.winner}</span>
							<span>${time}</span>
						</div>
					`;
				}).join('');
			}

			clearHistoryBtn.addEventListener('click', () => {
				localStorage.removeItem(HISTORY_KEY);
				renderHistory();
			});

			renderHistory();

			// ── Share Results ──────────────────────────────────────────────
			let lastPlayers = null;

			shareBtn.addEventListener('click', async () => {
				if (!lastPlayers) return;
				const [a, b] = lastPlayers;
				let text = `Mona Mayhem Battle Results\n`;
				text += `${a.username}: ${a.total.toLocaleString()} contributions\n`;
				text += `${b.username}: ${b.total.toLocaleString()} contributions\n`;

				if (a.error || b.error) {
					text += `Result: Incomplete battle`;
				} else if (a.total === b.total) {
					text += `Result: IT'S A TIE!`;
				} else {
					const winner = a.total > b.total ? a : b;
					text += `Winner: ${winner.username}!`;
				}

				try {
					await navigator.clipboard.writeText(text);
					copyConfirm.textContent = 'Copied to clipboard!';
					copyConfirm.classList.remove('hidden');
					setTimeout(() => copyConfirm.classList.add('hidden'), 2000);
				} catch {
					copyConfirm.textContent = 'Copy failed';
					copyConfirm.classList.remove('hidden');
					setTimeout(() => copyConfirm.classList.add('hidden'), 2000);
				}
			});

			// ── Commit Cannon Battle Animation ────────────────────────────
			const battleCanvas = document.querySelector('#battle-canvas');
			const battleCtx = battleCanvas.getContext('2d');

			function sampleArray(arr, max) {
				if (arr.length <= max) return [...arr];
				const step = arr.length / max;
				const out = [];
				for (let i = 0; i < max; i++) out.push(arr[Math.floor(i * step)]);
				return out;
			}

			function playImpactSound() {
				if (isMuted) return;
				const ctx = getAudioCtx();
				const now = ctx.currentTime;
				const osc = ctx.createOscillator();
				const gain = ctx.createGain();
				osc.type = 'square';
				osc.frequency.setValueAtTime(150, now);
				osc.frequency.exponentialRampToValueAtTime(40, now + 0.15);
				gain.gain.setValueAtTime(0.2, now);
				gain.gain.exponentialRampToValueAtTime(0.001, now + 0.2);
				osc.connect(gain).connect(ctx.destination);
				osc.start(now);
				osc.stop(now + 0.2);
			}

			function runBattleAnimation(players) {
				return new Promise((resolve) => {
					const [p1, p2] = players;
					if (p1.error || p2.error) { resolve(); return; }

					const section = document.querySelector('#battle-result');
					const rect = section.getBoundingClientRect();
					const dpr = window.devicePixelRatio || 1;
					battleCanvas.width = rect.width * dpr;
					battleCanvas.height = rect.height * dpr;
					battleCanvas.style.width = rect.width + 'px';
					battleCanvas.style.height = rect.height + 'px';
					battleCtx.scale(dpr, dpr);
					battleCanvas.classList.remove('hidden');

					const W = rect.width;
					const H = rect.height;
					const midX = W / 2;

					// Gather contribution days with count > 0
					const gatherDays = (player) => {
						const days = [];
						for (const week of player.weeks) {
							for (const day of week.contribution_days) {
								if (day.count > 0) days.push(day);
							}
						}
						return days;
					};

					const p1Days = sampleArray(gatherDays(p1), 40);
					const p2Days = sampleArray(gatherDays(p2), 40);

					const projectiles = [];
					const particles = [];
					let frame = 0;
					let p1Idx = 0, p2Idx = 0;
					const fireRate = 2; // frames between shots
					let winnerSide = p1.total >= p2.total ? 'left' : 'right';
					let resolved = false;

					function spawnProjectile(day, side, colors) {
						const color = colors[Math.min(day.level, colors.length - 1)] || '#5fed83';
						const r = 3 + day.level * 2;
						const speed = 4 + day.level * 1;
						const y = 30 + Math.random() * (H - 60);
						return {
							x: side === 'left' ? -r : W + r,
							y,
							vx: side === 'left' ? speed : -speed,
							vy: (Math.random() - 0.5) * 2,
							radius: r,
							color,
							alpha: 1,
							side,
							alive: true,
							trail: [],
						};
					}

					function explode(x, y, color, n) {
						for (let i = 0; i < n; i++) {
							const a = Math.random() * Math.PI * 2;
							const s = 1 + Math.random() * 4;
							particles.push({
								x, y,
								vx: Math.cos(a) * s,
								vy: Math.sin(a) * s,
								radius: 1 + Math.random() * 2.5,
								color,
								alpha: 1,
								life: 25 + Math.random() * 25,
								maxLife: 50,
							});
						}
					}

					function drawGlow(x, y, r, color) {
						const grad = battleCtx.createRadialGradient(x, y, 0, x, y, r * 3);
						grad.addColorStop(0, color);
						grad.addColorStop(1, 'transparent');
						battleCtx.fillStyle = grad;
						battleCtx.fillRect(x - r * 3, y - r * 3, r * 6, r * 6);
					}

					function tick() {
						battleCtx.clearRect(0, 0, W, H);

						// Fire projectiles
						if (frame % fireRate === 0) {
							if (p1Idx < p1Days.length) {
								projectiles.push(spawnProjectile(p1Days[p1Idx++], 'left', p1.colors));
							}
							if (p2Idx < p2Days.length) {
								projectiles.push(spawnProjectile(p2Days[p2Idx++], 'right', p2.colors));
							}
						}

						// Update projectiles
						for (const proj of projectiles) {
							if (!proj.alive) continue;

							// Store trail
							proj.trail.push({ x: proj.x, y: proj.y });
							if (proj.trail.length > 6) proj.trail.shift();

							proj.x += proj.vx;
							proj.y += proj.vy;
							proj.vy *= 0.99;

							// Collision with opposing projectiles near center
							for (const other of projectiles) {
								if (!other.alive || other.side === proj.side) continue;
								const dx = proj.x - other.x;
								const dy = proj.y - other.y;
								const dist = Math.sqrt(dx * dx + dy * dy);
								if (dist < proj.radius + other.radius + 2) {
									const cx = (proj.x + other.x) / 2;
									const cy = (proj.y + other.y) / 2;
									explode(cx, cy, proj.color, 6);
									explode(cx, cy, other.color, 6);
									proj.alive = false;
									other.alive = false;
									playImpactSound();
									break;
								}
							}

							// Hit the opposing side edge = breakthrough
							if (proj.alive) {
								if (proj.side === 'left' && proj.x > W + 20) proj.alive = false;
								if (proj.side === 'right' && proj.x < -20) proj.alive = false;
								if (proj.y < -20 || proj.y > H + 20) proj.alive = false;
							}

							// Draw trail
							if (proj.alive) {
								for (let t = 0; t < proj.trail.length; t++) {
									const tp = proj.trail[t];
									const a = (t / proj.trail.length) * 0.3;
									battleCtx.globalAlpha = a;
									battleCtx.beginPath();
									battleCtx.arc(tp.x, tp.y, proj.radius * 0.6, 0, Math.PI * 2);
									battleCtx.fillStyle = proj.color;
									battleCtx.fill();
								}
								battleCtx.globalAlpha = 1;

								// Draw projectile with glow
								drawGlow(proj.x, proj.y, proj.radius, proj.color + '44');
								battleCtx.beginPath();
								battleCtx.arc(proj.x, proj.y, proj.radius, 0, Math.PI * 2);
								battleCtx.fillStyle = proj.color;
								battleCtx.shadowColor = proj.color;
								battleCtx.shadowBlur = 12;
								battleCtx.fill();
								battleCtx.shadowBlur = 0;
							}
						}

						// Update particles
						for (let i = particles.length - 1; i >= 0; i--) {
							const p = particles[i];
							p.x += p.vx;
							p.y += p.vy;
							p.vx *= 0.96;
							p.vy *= 0.96;
							p.life--;
							p.alpha = Math.max(0, p.life / p.maxLife);

							if (p.life <= 0) { particles.splice(i, 1); continue; }

							battleCtx.globalAlpha = p.alpha;
							battleCtx.beginPath();
							battleCtx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
							battleCtx.fillStyle = p.color;
							battleCtx.shadowColor = p.color;
							battleCtx.shadowBlur = 6;
							battleCtx.fill();
							battleCtx.shadowBlur = 0;
						}
						battleCtx.globalAlpha = 1;

						frame++;

						// End conditions
						const allFired = p1Idx >= p1Days.length && p2Idx >= p2Days.length;
						const aliveCount = projectiles.filter(p => p.alive).length;

						if ((allFired && aliveCount === 0 && particles.length === 0) || frame > 350) {
							if (!resolved) {
								resolved = true;
								// Apply visual effects to cards
								const cards = arenaEl.querySelectorAll('.player-card');
								if (cards.length === 2) {
									const loserIdx = winnerSide === 'left' ? 1 : 0;
									const winnerIdx = winnerSide === 'left' ? 0 : 1;
									if (p1.total !== p2.total) {
										cards[loserIdx].classList.add('cracked');
										cards[winnerIdx].classList.add('winner-flash');
									}
								}
								// Fade out canvas
								setTimeout(() => {
									battleCanvas.classList.add('hidden');
									battleCtx.setTransform(1, 0, 0, 1, 0, 0);
									resolve();
								}, 400);
							}
							return;
						}

						requestAnimationFrame(tick);
					}

					requestAnimationFrame(tick);
				});
			}

			// ── Main Battle Handler ───────────────────────────────────────
			async function handleBattle() {
				clearError(input1, error1);
				clearError(input2, error2);
				bannerEl.classList.add('hidden');
				shareBtn.classList.add('hidden');
				copyConfirm.classList.add('hidden');

				const p1 = normalize(input1.value);
				const p2 = normalize(input2.value);
				let hasError = false;

				if (!p1 || !isValidUsername(p1)) {
					showError(input1, error1, p1 ? 'Invalid username' : 'Enter a username');
					hasError = true;
				}
				if (!p2 || !isValidUsername(p2)) {
					showError(input2, error2, p2 ? 'Invalid username' : 'Enter a username');
					hasError = true;
				}

				if (hasError) {
					playErrorSound();
					form.classList.add('shake');
					setTimeout(() => form.classList.remove('shake'), 500);
					return;
				}

				playCoinSound();
				button.disabled = true;
				button.textContent = 'Battling...';
				statusEl.textContent = 'Fetching contribution data...';
				statusEl.className = 'loading';

				renderLoadingSkeleton();

				const [, results] = await Promise.all([
					playCountdown(),
					Promise.allSettled([fetchPlayer(p1), fetchPlayer(p2)])
				]);

				const players = results.map((result, i) => {
					if (result.status === 'fulfilled') return result.value;
					return {
						username: [p1, p2][i],
						total: 0,
						from: '',
						to: '',
						colors: DEFAULT_COLORS,
						weeks: [],
						error: true,
						errorMessage: result.reason?.message || 'Failed to load',
					};
				});

				lastPlayers = players;
				render(players);

				// Run commit cannon battle animation
				await runBattleAnimation(players);

				renderWinnerBanner(players);

				const anyError = players.some(p => p.error);
				if (anyError) {
					playErrorSound();
				} else {
					playPowerUpSound();
				}

				// Save to history
				const valid = players.filter(p => !p.error);
				if (valid.length === 2) {
					const winner = valid[0].total > valid[1].total ? valid[0].username
						: valid[1].total > valid[0].total ? valid[1].username
						: 'Tie';
					saveHistory({
						p1: { name: valid[0].username, total: valid[0].total },
						p2: { name: valid[1].username, total: valid[1].total },
						winner,
						time: Date.now(),
					});
					renderHistory();
				}

				shareBtn.classList.remove('hidden');
				statusEl.className = 'hidden';
				button.disabled = false;
				button.textContent = 'Battle!';
			}

			form.addEventListener('submit', (e) => {
				e.preventDefault();
				handleBattle();
			});
		</script>
	</body>
</html>
