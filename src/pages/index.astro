---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<style>
			/* ── Colour themes ────────────────────────────────────────────── */

			/* Default: green / purple (retro-arcade classic) */
			:root {
				--theme-primary:       #22c55e;
				--theme-primary-glow:  rgba(34, 197, 94, 0.3);
				--theme-vs-start:      #667eea;
				--theme-vs-end:        #764ba2;
				--theme-vs-shadow:     rgba(102, 126, 234, 0.4);
				--theme-winner-bg:     linear-gradient(135deg, #d1fae5, #a7f3d0);
				--theme-winner-text:   #065f46;
			}

			/* Alternative: blue / orange (electric arcade) */
			[data-theme="blue-orange"] {
				--theme-primary:       #00f5ff;
				--theme-primary-glow:  rgba(0, 245, 255, 0.3);
				--theme-vs-start:      #ff6b35;
				--theme-vs-end:        #ff9f1c;
				--theme-vs-shadow:     rgba(255, 107, 53, 0.4);
				--theme-winner-bg:     linear-gradient(135deg, #fff3e0, #ffe0cc);
				--theme-winner-text:   #7c2d12;
			}

			/* ── Base styles ──────────────────────────────────────────────── */

			body {
				font-family: Arial, Helvetica, sans-serif;
				margin: 0;
				padding: 1.5rem;
				background: #f4f4f4;
				color: #111827;
				display: grid;
				place-items: center;
				min-height: 100vh;
			}

			.container {
				width: min(900px, 100%);
				padding: 1.5rem;
				border-radius: 10px;
				background: #ffffff;
				border: 1px solid #d1d5db;
				box-sizing: border-box;
				position: relative;
			}

			h1 {
				font-size: 1.6rem;
				margin: 0 0 0.75rem;
			}

			p {
				margin: 0 0 1rem;
				color: #4b5563;
			}

			form {
				display: grid;
				grid-template-columns: 1fr 1fr auto;
				gap: 0.9rem;
				align-items: end;
			}

			@media (max-width: 600px) {
				form {
					grid-template-columns: 1fr;
				}
			}

			.field {
				display: grid;
				gap: 0.35rem;
			}

			label {
				font-weight: 600;
			}

			input {
				padding: 0.65rem 0.75rem;
				border: 1px solid #d1d5db;
				border-radius: 6px;
				font-size: 1rem;
			}

			input.error {
				border-color: #dc2626;
			}

			button {
				padding: 0.65rem 1.25rem;
				border: 0;
				border-radius: 6px;
				background: #111827;
				color: #fff;
				font-weight: 600;
				cursor: pointer;
				height: fit-content;
			}

			button:disabled {
				background: #9ca3af;
				cursor: not-allowed;
			}

			#battle-result {
				margin-top: 1.5rem;
			}

			#status {
				margin-bottom: 0.75rem;
				font-weight: 600;
				text-align: center;
			}

			.error-message {
				color: #dc2626;
				font-size: 0.875rem;
				margin-top: 0.25rem;
			}

			/* Battle arena layout */
			.battle-arena {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				gap: 1rem;
				align-items: start;
			}

			@media (max-width: 700px) {
				.battle-arena {
					grid-template-columns: 1fr;
				}
				.vs-badge {
					justify-self: center;
				}
			}

			/* Player card */
			.player-card {
				border: 2px solid #d1d5db;
				border-radius: 8px;
				padding: 1rem;
				background: #fff;
				transition: border-color 0.3s;
			}

			.player-card.winner {
				border-color: var(--theme-primary);
				box-shadow: 0 0 12px var(--theme-primary-glow);
			}

			.player-card.loser {
				opacity: 0.7;
			}

			.player-card.error {
				border-color: #dc2626;
				background: #fef2f2;
			}

			.player-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.5rem;
			}

			.player-name {
				font-weight: 700;
				font-size: 1.1rem;
			}

			.player-total {
				font-size: 1.25rem;
				font-weight: 700;
				color: var(--theme-primary);
			}

			.player-date-range {
				color: #6b7280;
				font-size: 0.8rem;
				margin-bottom: 0.75rem;
			}

			/* VS Badge */
			.vs-badge {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 50px;
				height: 50px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--theme-vs-start), var(--theme-vs-end));
				color: #fff;
				font-weight: 800;
				font-size: 1rem;
				align-self: center;
				box-shadow: 0 4px 12px var(--theme-vs-shadow);
			}

			/* Contribution grid */
			.contrib-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				grid-template-rows: repeat(7, 1fr);
				gap: 2px;
				width: 100%;
				aspect-ratio: 53 / 7;
			}

			.contrib-cell {
				border-radius: 2px;
				position: relative;
				cursor: default;
			}

			.contrib-cell[data-count]::after {
				content: attr(data-count) " contributions";
				position: absolute;
				bottom: calc(100% + 4px);
				left: 50%;
				transform: translateX(-50%);
				background: #1f2937;
				color: #fff;
				padding: 4px 8px;
				border-radius: 4px;
				font-size: 0.7rem;
				white-space: nowrap;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.15s;
				z-index: 10;
			}

			.contrib-cell:hover::after {
				opacity: 1;
			}

			/* Loading skeleton */
			.skeleton {
				background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
				background-size: 200% 100%;
				animation: skeleton-loading 1.5s infinite;
			}

			@keyframes skeleton-loading {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}

			.skeleton-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				grid-template-rows: repeat(7, 1fr);
				gap: 2px;
				width: 100%;
				aspect-ratio: 53 / 7;
			}

			.skeleton-cell {
				background: #e5e7eb;
				border-radius: 2px;
			}

			.skeleton-text {
				height: 1rem;
				border-radius: 4px;
				margin-bottom: 0.5rem;
			}

			.skeleton-text.short {
				width: 40%;
			}

			.skeleton-text.medium {
				width: 60%;
			}

			/* Result banner */
			#result {
				text-align: center;
				font-size: 1.1rem;
				font-weight: 600;
				padding: 1rem;
				margin-top: 1rem;
				border-radius: 6px;
				background: #f3f4f6;
			}

			#result.winner-announced {
				background: var(--theme-winner-bg);
				color: var(--theme-winner-text);
			}

			#result.tie {
				background: linear-gradient(135deg, #fef3c7, #fde68a);
				color: #92400e;
			}

			.hidden {
				display: none !important;
			}

			/* ── Theme toggle ─────────────────────────────────────────────── */

			.theme-toggle {
				position: absolute;
				top: 1rem;
				right: 1rem;
				padding: 0.4rem 0.85rem;
				border: 2px solid var(--theme-primary);
				border-radius: 20px;
				background: transparent;
				color: var(--theme-primary);
				font-size: 0.8rem;
				font-weight: 700;
				cursor: pointer;
				letter-spacing: 0.05em;
				transition: background 0.2s, color 0.2s;
			}

			.theme-toggle:hover {
				background: var(--theme-primary);
				color: #000;
			}

		</style>
	</head>
	<body>
		<main class="container">
			<button id="theme-toggle" class="theme-toggle" aria-label="Toggle colour theme" title="Switch colour theme">🎨 Blue / Orange</button>
			<h1>Mona Mayhem - GitHub Contribution Battle Arena</h1>
			<p>Enter two GitHub usernames and start a quick contribution battle.</p>

			<form id="battle-form">
				<div class="field">
					<label for="player1">Player 1</label>
					<input id="player1" name="player1" placeholder="e.g. octocat" autocomplete="off" />
					<div id="player1-error" class="error-message hidden"></div>
				</div>
				<div class="field">
					<label for="player2">Player 2</label>
					<input id="player2" name="player2" placeholder="e.g. mona" autocomplete="off" />
					<div id="player2-error" class="error-message hidden"></div>
				</div>
			<button id="battle-btn" type="submit">Battle</button>
			</form>

			<section id="battle-result" aria-live="polite">
				<div id="status" class="hidden"></div>
				<div id="arena" class="hidden"></div>
				<div id="result" class="hidden"></div>
			</section>
		</main>

		<script type="module">
			// ── Theme toggle ──────────────────────────────────────────────────
			const THEME_KEY = 'mona-mayhem-theme';
			const BLUE_ORANGE = 'blue-orange';

			const themeToggleBtn = /** @type {HTMLButtonElement} */ (document.querySelector('#theme-toggle'));

			function applyTheme(theme) {
				if (theme === BLUE_ORANGE) {
					document.documentElement.setAttribute('data-theme', BLUE_ORANGE);
					themeToggleBtn.textContent = '🎨 Green / Purple';
				} else {
					document.documentElement.removeAttribute('data-theme');
					themeToggleBtn.textContent = '🎨 Blue / Orange';
				}
			}

			// Restore saved preference on load
			applyTheme((typeof window !== 'undefined' && localStorage.getItem(THEME_KEY)) || '');

			themeToggleBtn.addEventListener('click', () => {
				const next = document.documentElement.getAttribute('data-theme') === BLUE_ORANGE ? '' : BLUE_ORANGE;
				if (typeof window !== 'undefined') {
					localStorage.setItem(THEME_KEY, next);
				}
				applyTheme(next);
			});

			// ── Battle logic ──────────────────────────────────────────────────
			// TypeScript interfaces (as JSDoc for vanilla JS module)
			/**
			 * @typedef {Object} ContributionDay
			 * @property {number} weekday - Day of week (0=Sun, 6=Sat)
			 * @property {number} count - Number of contributions
			 * @property {number} level - Intensity level (0-4)
			 */

			/**
			 * @typedef {Object} ContributionWeek
			 * @property {number} index - Week index
			 * @property {string} first_day - First day of week (YYYY-MM-DD)
			 * @property {ContributionDay[]} contribution_days - Days in the week
			 */

			/**
			 * @typedef {Object} ContributionData
			 * @property {string} schema - Schema version
			 * @property {string} generated_at - ISO timestamp
			 * @property {string} from - Date range start (YYYY-MM-DD)
			 * @property {string} to - Date range end (YYYY-MM-DD)
			 * @property {number} range_days - Number of days in range
			 * @property {number} total_contributions - Total contribution count
			 * @property {boolean} private_contributions_included - Whether private contribs are included
			 * @property {string[]} colors_full - GitHub color palette
			 * @property {ContributionWeek[]} weeks - Weekly contribution data
			 */

			/**
			 * @typedef {Object} APIResponse
			 * @property {string} username
			 * @property {number} fetchedAt
			 * @property {string} cacheStatus
			 * @property {string} source
			 * @property {ContributionData} data
			 */

			/**
			 * @typedef {Object} PlayerData
			 * @property {string} username
			 * @property {number} total
			 * @property {string} from
			 * @property {string} to
			 * @property {string[]} colors
			 * @property {ContributionWeek[]} weeks
			 * @property {boolean} [error]
			 * @property {string} [errorMessage]
			 */

			const DEFAULT_COLORS = ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'];

			// DOM elements
			const form = /** @type {HTMLFormElement} */ (document.querySelector('#battle-form'));
			const button = /** @type {HTMLButtonElement} */ (document.querySelector('#battle-btn'));
			const statusEl = /** @type {HTMLElement} */ (document.querySelector('#status'));
			const arenaEl = /** @type {HTMLElement} */ (document.querySelector('#arena'));
			const resultEl = /** @type {HTMLElement} */ (document.querySelector('#result'));

			const playerInput1 = /** @type {HTMLInputElement} */ (document.querySelector('#player1'));
			const playerInput2 = /** @type {HTMLInputElement} */ (document.querySelector('#player2'));
			const playerError1 = /** @type {HTMLElement} */ (document.querySelector('#player1-error'));
			const playerError2 = /** @type {HTMLElement} */ (document.querySelector('#player2-error'));

			/**
			 * @param {string} message
			 */
			function setStatus(message) {
				statusEl.textContent = message;
				statusEl.classList.toggle('hidden', !message);
			}

			/**
			 * @param {string|undefined} name
			 * @returns {string}
			 */
			function normalize(name) {
				return (name || '').trim().toLowerCase();
			}

			/**
			 * @param {HTMLInputElement} input
			 * @param {HTMLElement} errorEl
			 * @param {string} message
			 */
			function showFieldError(input, errorEl, message) {
				input.classList.add('error');
				errorEl.textContent = message;
				errorEl.classList.remove('hidden');
			}

			/**
			 * @param {HTMLInputElement} input
			 * @param {HTMLElement} errorEl
			 */
			function clearFieldError(input, errorEl) {
				input.classList.remove('error');
				errorEl.textContent = '';
				errorEl.classList.add('hidden');
			}

			function clearAllErrors() {
				clearFieldError(playerInput1, playerError1);
				clearFieldError(playerInput2, playerError2);
			}

			/**
			 * @param {string} dateStr - YYYY-MM-DD format
			 * @returns {string}
			 */
			function formatDate(dateStr) {
				const date = new Date(dateStr);
				return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
			}

			/**
			 * @param {string} username
			 * @returns {Promise<PlayerData>}
			 */
			async function fetchPlayer(username) {
				const response = await fetch(`/api/contributions/${encodeURIComponent(username)}`);
				const payload = /** @type {APIResponse} */ (await response.json());

				if (!response.ok) {
					const message = payload?.error?.message || `Request failed (${response.status})`;
					throw new Error(message);
				}

				const data = payload.data;
				return {
					username,
					total: data.total_contributions || 0,
					from: data.from,
					to: data.to,
					colors: data.colors_full || DEFAULT_COLORS,
					weeks: data.weeks || [],
				};
			}

			/**
			 * Render a contribution grid as HTML
			 * @param {PlayerData} player
			 * @returns {string}
			 */
			function renderGrid(player) {
				if (player.error || !player.weeks) {
					return '<div class="contrib-grid"></div>';
				}

				const cells = [];
				for (const week of player.weeks) {
					for (const day of week.contribution_days) {
						const color = player.colors[day.level] || player.colors[0];
						cells.push(
							`<div class="contrib-cell" style="background:${color}" data-count="${day.count}"></div>`
						);
					}
				}

				return `<div class="contrib-grid">${cells.join('')}</div>`;
			}

			/**
			 * Render a player card
			 * @param {PlayerData} player
			 * @param {'winner'|'loser'|'tie'|'error'|null} status
			 * @returns {string}
			 */
			function renderPlayerCard(player, status) {
				const statusClass = status ? ` ${status}` : '';

				if (player.error) {
					return `
						<div class="player-card error">
							<div class="player-header">
								<span class="player-name">${player.username}</span>
							</div>
							<div class="error-message">${player.errorMessage || 'Failed to load'}</div>
						</div>
					`;
				}

				const dateRange = player.from && player.to
					? `${formatDate(player.from)} – ${formatDate(player.to)}`
					: '';

				return `
					<div class="player-card${statusClass}">
						<div class="player-header">
							<span class="player-name">${player.username}</span>
							<span class="player-total">${player.total.toLocaleString()}</span>
						</div>
						<div class="player-date-range">${dateRange}</div>
						${renderGrid(player)}
					</div>
				`;
			}

			function renderLoadingSkeleton() {
				const skeletonCells = Array(53 * 7).fill('<div class="skeleton-cell skeleton"></div>').join('');
				const skeletonCard = `
					<div class="player-card">
						<div class="skeleton skeleton-text short"></div>
						<div class="skeleton skeleton-text medium"></div>
						<div class="skeleton-grid">${skeletonCells}</div>
					</div>
				`;

				arenaEl.innerHTML = `
					<div class="battle-arena">
						${skeletonCard}
						<div class="vs-badge">VS</div>
						${skeletonCard}
					</div>
				`;
				arenaEl.classList.remove('hidden');
			}

			/**
			 * @param {PlayerData[]} players
			 */
			function render(players) {
				const [p1, p2] = players;
				const validPlayers = players.filter(p => !p.error);

				let p1Status = null;
				let p2Status = null;

				if (validPlayers.length === 2) {
					if (p1.total > p2.total) {
						p1Status = 'winner';
						p2Status = 'loser';
					} else if (p2.total > p1.total) {
						p1Status = 'loser';
						p2Status = 'winner';
					} else {
						p1Status = 'tie';
						p2Status = 'tie';
					}
				} else if (p1.error) {
					p1Status = 'error';
				} else if (p2.error) {
					p2Status = 'error';
				}

				arenaEl.innerHTML = `
					<div class="battle-arena">
						${renderPlayerCard(p1, p1Status)}
						<div class="vs-badge">VS</div>
						${renderPlayerCard(p2, p2Status)}
					</div>
				`;
				arenaEl.classList.remove('hidden');
			}

			/**
			 * @param {PlayerData[]} players
			 */
			function renderResult(players) {
				const valid = players.filter(p => !p.error);

				if (valid.length < 2) {
					if (valid.length === 1) {
						resultEl.textContent = `🏆 ${valid[0].username} wins by default!`;
						resultEl.className = 'winner-announced';
					} else {
						resultEl.textContent = 'Both players failed to load. Please try again.';
						resultEl.className = '';
					}
					resultEl.classList.remove('hidden');
					return;
				}

				const [a, b] = valid;
				if (a.total === b.total) {
					resultEl.textContent = `🤝 It's a tie! Both have ${a.total.toLocaleString()} contributions.`;
					resultEl.className = 'tie';
				} else {
					const winner = a.total > b.total ? a : b;
					const diff = Math.abs(a.total - b.total);
					resultEl.textContent = `🏆 ${winner.username} wins with ${winner.total.toLocaleString()} contributions! (+${diff.toLocaleString()})`;
					resultEl.className = 'winner-announced';
				}
				resultEl.classList.remove('hidden');
			}

			async function handleBattle() {
				clearAllErrors();
				resultEl.classList.add('hidden');

				const player1 = normalize(playerInput1.value);
				const player2 = normalize(playerInput2.value);

				let hasError = false;

				if (!player1) {
					showFieldError(playerInput1, playerError1, 'Please enter a username');
					hasError = true;
				}

				if (!player2) {
					showFieldError(playerInput2, playerError2, 'Please enter a username');
					hasError = true;
				}

				if (hasError) {
					return;
				}

				setStatus('Fetching contribution data...');
				button.disabled = true;
				button.textContent = 'Battling...';
				renderLoadingSkeleton();

				const usernames = [player1, player2];
				const results = await Promise.allSettled(usernames.map(fetchPlayer));

				/** @type {PlayerData[]} */
				const loaded = results.map((result, index) => {
					if (result.status === 'fulfilled') {
						return result.value;
					}

					return {
						username: usernames[index],
						total: 0,
						from: '',
						to: '',
						colors: DEFAULT_COLORS,
						weeks: [],
						error: true,
						errorMessage: result.reason?.message || 'Failed to load',
					};
				});

				render(loaded);
				renderResult(loaded);
				setStatus('');
				button.disabled = false;
				button.textContent = 'Battle';
			}

			// Form submission
			form.addEventListener('submit', (event) => {
				event.preventDefault();
				handleBattle();
			});

			// Enter key in inputs
			playerInput1.addEventListener('keydown', (event) => {
				if (event.key === 'Enter') {
					event.preventDefault();
					handleBattle();
				}
			});

			playerInput2.addEventListener('keydown', (event) => {
				if (event.key === 'Enter') {
					event.preventDefault();
					handleBattle();
				}
			});

			// Clear errors on input
			playerInput1.addEventListener('input', () => clearFieldError(playerInput1, playerError1));
			playerInput2.addEventListener('input', () => clearFieldError(playerInput2, playerError2));
		</script>
	</body>
</html>
