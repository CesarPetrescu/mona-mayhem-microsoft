<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<style is:global>
			/* ── Themes ────────────────────────────────────────────────── */
			:root {
				--bg: #050510;
				--screen-bg: #0a0a14;
				--panel: #0c0c1e;
				--panel-border: #1a3a1a;
				--text: #b0ccb0;
				--text-dim: #4a6a4a;
				--accent-1: #33ff66;
				--accent-2: #a855f7;
				--accent-error: #ff3366;
				--font-term: 'Share Tech Mono', 'Courier New', monospace;
				--font-retro: 'Press Start 2P', monospace;
			}

			[data-theme="blue-orange"] {
				--accent-1: #00e5ff;
				--accent-2: #ff6b35;
				--panel-border: #1a2a3a;
				--text: #b0c8e0;
				--text-dim: #3a5570;
			}

			/* ── Keyframes ─────────────────────────────────────────────── */
			@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
			@keyframes scanDown { from { top: -4px; } to { top: 100%; } }
			@keyframes noiseShift {
				0% { transform: translate(0, 0); }
				25% { transform: translate(-2px, 1px); }
				50% { transform: translate(1px, -1px); }
				75% { transform: translate(-1px, 2px); }
				100% { transform: translate(0, 0); }
			}
			@keyframes flicker {
				0%, 100% { opacity: 1; }
				92% { opacity: 1; }
				93% { opacity: 0.96; }
				94% { opacity: 1; }
				97% { opacity: 0.98; }
				98% { opacity: 1; }
			}
			@keyframes phosphorGlow {
				0%, 100% { box-shadow: inset 0 0 60px rgba(51, 255, 102, 0.03), inset 0 0 120px rgba(51, 255, 102, 0.01); }
				50% { box-shadow: inset 0 0 80px rgba(51, 255, 102, 0.05), inset 0 0 160px rgba(51, 255, 102, 0.02); }
			}
			@keyframes gradientShift {
				0% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
				100% { background-position: 0% 50%; }
			}
			@keyframes slideInLeft {
				from { opacity: 0; transform: translateX(-30px); }
				to { opacity: 1; transform: translateX(0); }
			}
			@keyframes slideInRight {
				from { opacity: 0; transform: translateX(30px); }
				to { opacity: 1; transform: translateX(0); }
			}
			@keyframes bannerPop {
				0% { transform: scale(0); opacity: 0; }
				60% { transform: scale(1.08); }
				100% { transform: scale(1); opacity: 1; }
			}
			@keyframes heatWave {
				0%, 100% { filter: brightness(1) hue-rotate(0deg); }
				50% { filter: brightness(1.15) hue-rotate(8deg); }
			}
			@keyframes shake {
				0%, 100% { transform: translateX(0); }
				15%, 55%, 85% { transform: translateX(-3px); }
				35%, 75% { transform: translateX(3px); }
			}
			@keyframes countdownPulse {
				0% { transform: scale(0.5); opacity: 0; }
				50% { transform: scale(1.3); opacity: 1; }
				100% { transform: scale(1); opacity: 0.9; }
			}
			@keyframes skeleton-loading {
				0% { background-position: 200% 0; }
				100% { background-position: -200% 0; }
			}
			@keyframes cardCrack {
				0% { transform: scale(1); filter: brightness(1); }
				30% { transform: scale(0.97) rotate(-0.5deg); filter: brightness(2); }
				60% { transform: scale(0.99) rotate(0.3deg); filter: brightness(0.4); }
				100% { transform: scale(1); filter: brightness(0.5); opacity: 0.5; }
			}
			@keyframes winnerFlash {
				0% { filter: brightness(1); }
				40% { filter: brightness(1.6); }
				100% { filter: brightness(1); }
			}

			/* ── Base ──────────────────────────────────────────────────── */
			* { box-sizing: border-box; }

			body {
				font-family: var(--font-term);
				margin: 0;
				padding: 2rem 1rem;
				background: var(--bg);
				color: var(--text);
				display: grid;
				place-items: center;
				min-height: 100vh;
				line-height: 1.7;
			}

			/* ── CRT Monitor Shell ─────────────────────────────────────── */
			.crt-monitor {
				position: relative;
				background: linear-gradient(145deg, #1c1c1c 0%, #111 40%, #0a0a0a 100%);
				border-radius: 28px;
				padding: 28px 28px 14px;
				max-width: 960px;
				width: 100%;
				box-shadow:
					0 0 0 2px #222,
					0 0 0 5px #0a0a0a,
					0 12px 60px rgba(0, 0, 0, 0.9),
					inset 0 1px 0 rgba(255, 255, 255, 0.06);
			}

			/* Screws */
			.crt-monitor::before, .crt-monitor::after {
				content: '+';
				position: absolute;
				font-family: monospace;
				font-size: 10px;
				color: #333;
				top: 10px;
			}
			.crt-monitor::before { left: 14px; }
			.crt-monitor::after { right: 14px; }

			.crt-brand {
				text-align: center;
				font-family: var(--font-term);
				font-size: 0.65rem;
				color: #444;
				letter-spacing: 6px;
				text-transform: uppercase;
				padding: 8px 0 2px;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
			}

			.crt-led {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent-1);
				box-shadow: 0 0 4px var(--accent-1), 0 0 8px var(--accent-1);
				animation: blink 3s ease-in-out infinite;
			}

			/* ── CRT Screen ────────────────────────────────────────────── */
			.crt-screen {
				position: relative;
				border-radius: 14px / 16px;
				overflow: hidden;
				background: var(--screen-bg);
				border: 2px solid #1a1a1a;
				animation: phosphorGlow 6s ease-in-out infinite;
			}

			/* Scanlines */
			.crt-screen > .crt-scanlines {
				position: absolute;
				inset: 0;
				background: repeating-linear-gradient(
					0deg,
					transparent 0px,
					transparent 1px,
					rgba(0, 0, 0, 0.12) 1px,
					rgba(0, 0, 0, 0.12) 3px
				);
				pointer-events: none;
				z-index: 100;
			}

			/* Moving scan bar */
			.crt-screen > .crt-scanbar {
				position: absolute;
				left: 0;
				right: 0;
				height: 4px;
				background: linear-gradient(180deg, transparent, rgba(51, 255, 102, 0.06), transparent);
				pointer-events: none;
				z-index: 101;
				animation: scanDown 8s linear infinite;
			}

			/* Noise / static */
			.crt-screen > .crt-noise {
				position: absolute;
				inset: -50%;
				width: 200%;
				height: 200%;
				pointer-events: none;
				z-index: 99;
				opacity: 0.035;
				filter: url(#noiseFilter);
				background: #888;
				animation: noiseShift 0.15s steps(3) infinite;
			}

			/* Vignette — dark curved edges */
			.crt-screen > .crt-vignette {
				position: absolute;
				inset: 0;
				background: radial-gradient(
					ellipse 80% 75% at 50% 50%,
					transparent 50%,
					rgba(0, 0, 0, 0.4) 78%,
					rgba(0, 0, 0, 0.8) 100%
				);
				pointer-events: none;
				z-index: 102;
			}

			/* Chromatic aberration at edges */
			.crt-screen > .crt-aberration {
				position: absolute;
				inset: 0;
				pointer-events: none;
				z-index: 103;
				box-shadow:
					inset 4px 0 12px -4px rgba(255, 30, 60, 0.12),
					inset -4px 0 12px -4px rgba(40, 180, 255, 0.12),
					inset 0 3px 10px -3px rgba(255, 30, 60, 0.06),
					inset 0 -3px 10px -3px rgba(40, 180, 255, 0.06);
			}

			/* Glass glare */
			.crt-screen > .crt-glare {
				position: absolute;
				top: 3%;
				left: 8%;
				width: 40%;
				height: 20%;
				background: linear-gradient(
					135deg,
					rgba(255, 255, 255, 0.04) 0%,
					rgba(255, 255, 255, 0.01) 50%,
					transparent 100%
				);
				border-radius: 50%;
				pointer-events: none;
				z-index: 104;
				filter: blur(6px);
			}

			/* Flicker on content */
			.crt-screen > .screen-content {
				animation: flicker 10s linear infinite;
				position: relative;
				z-index: 1;
			}

			/* ── Terminal Container ────────────────────────────────────── */
			.container {
				width: 100%;
				padding: 1.5rem;
				position: relative;
			}

			/* ── Terminal Header Bar ───────────────────────────────────── */
			.term-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				border-bottom: 1px solid var(--panel-border);
				padding-bottom: 0.5rem;
				margin-bottom: 1rem;
			}

			.term-header-left {
				display: flex;
				gap: 6px;
			}

			.term-dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
			}
			.term-dot.red { background: #ff5f56; }
			.term-dot.yellow { background: #ffbd2e; }
			.term-dot.green { background: #27c93f; }

			.term-title {
				font-family: var(--font-term);
				font-size: 0.7rem;
				color: var(--text-dim);
			}

			.controls {
				display: flex;
				gap: 0.5rem;
			}

			.control-btn {
				padding: 2px 8px;
				border: 1px solid var(--panel-border);
				border-radius: 2px;
				background: transparent;
				color: var(--text-dim);
				font-family: var(--font-term);
				font-size: 0.65rem;
				cursor: pointer;
				transition: color 0.2s, border-color 0.2s;
			}

			.control-btn:hover {
				color: var(--accent-1);
				border-color: var(--accent-1);
			}

			/* ── Title ─────────────────────────────────────────────────── */
			.title-block {
				text-align: center;
				margin-bottom: 1.2rem;
			}

			h1 {
				font-family: var(--font-retro);
				font-size: 1rem;
				margin: 0 0 0.3rem;
				color: var(--accent-1);
				text-shadow: 0 0 10px var(--accent-1), 0 0 30px rgba(51, 255, 102, 0.3);
			}

			.subtitle {
				margin: 0;
				color: var(--text-dim);
				font-size: 0.7rem;
			}

			/* ── Terminal Prompt / Form ─────────────────────────────────── */
			.input-grid {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				gap: 1rem;
				align-items: end;
				margin-bottom: 0.75rem;
			}

			.input-block {
				display: flex;
				flex-direction: column;
				gap: 4px;
			}

			.input-block label {
				font-size: 0.65rem;
				color: var(--accent-2);
				font-weight: normal;
			}

			.prompt-line {
				display: flex;
				align-items: center;
				background: var(--panel);
				border: 1px solid var(--panel-border);
				border-radius: 3px;
				padding: 0;
				overflow: hidden;
			}

			.prompt-char {
				padding: 0.5rem 0.4rem 0.5rem 0.6rem;
				color: var(--accent-1);
				font-family: var(--font-term);
				font-size: 0.8rem;
				user-select: none;
				flex-shrink: 0;
			}

			.prompt-line input {
				flex: 1;
				padding: 0.5rem 0.6rem 0.5rem 0;
				border: none;
				background: transparent;
				color: var(--text);
				font-family: var(--font-term);
				font-size: 0.8rem;
				outline: none;
				caret-color: var(--accent-1);
			}

			.prompt-line:focus-within {
				border-color: var(--accent-1);
				box-shadow: 0 0 8px rgba(51, 255, 102, 0.15);
			}

			.prompt-line.input-error {
				border-color: var(--accent-error);
				box-shadow: 0 0 8px rgba(255, 51, 102, 0.2);
			}

			.error-msg {
				color: var(--accent-error);
				font-size: 0.6rem;
				min-height: 1em;
			}

			/* ── VS Badge ──────────────────────────────────────────────── */
			.vs-badge {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 44px;
				height: 44px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent-1), var(--accent-2), var(--accent-1));
				background-size: 200% 200%;
				animation: gradientShift 4s ease infinite;
				color: #000;
				font-weight: 700;
				font-size: 0.65rem;
				font-family: var(--font-retro);
				align-self: center;
				flex-shrink: 0;
			}

			/* ── Execute Button ─────────────────────────────────────────── */
			#battle-btn {
				width: 100%;
				padding: 0.6rem;
				border: 1px solid var(--accent-1);
				border-radius: 3px;
				background: rgba(51, 255, 102, 0.05);
				color: var(--accent-1);
				font-family: var(--font-retro);
				font-size: 0.65rem;
				cursor: pointer;
				text-transform: uppercase;
				letter-spacing: 3px;
				transition: background 0.2s, box-shadow 0.2s;
			}

			#battle-btn:hover:not(:disabled) {
				background: rgba(51, 255, 102, 0.12);
				box-shadow: 0 0 20px rgba(51, 255, 102, 0.15);
			}

			#battle-btn:disabled {
				border-color: var(--text-dim);
				color: var(--text-dim);
				background: transparent;
				cursor: not-allowed;
			}

			form.shake { animation: shake 0.4s ease-in-out; }

			/* ── Focus ─────────────────────────────────────────────────── */
			*:focus-visible {
				outline: 1px solid var(--accent-1);
				outline-offset: 2px;
			}

			/* ── Terminal Log / Status ──────────────────────────────────── */
			#status {
				font-size: 0.7rem;
				margin: 0.75rem 0;
				padding: 0;
				color: var(--text-dim);
			}

			#status .log-line {
				display: block;
				margin-bottom: 2px;
			}

			#status .log-line::before {
				content: '> ';
				color: var(--accent-1);
			}

			.cursor-blink {
				display: inline-block;
				width: 7px;
				height: 1em;
				background: var(--accent-1);
				animation: blink 1s step-end infinite;
				vertical-align: text-bottom;
				margin-left: 2px;
			}

			/* ── Battle Arena ──────────────────────────────────────────── */
			#battle-result {
				position: relative;
			}

			.battle-arena {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				gap: 0.75rem;
				align-items: start;
				margin-top: 0.75rem;
			}

			/* ── Player Card — console output block ────────────────────── */
			.player-card {
				border: 1px solid var(--panel-border);
				border-radius: 4px;
				padding: 0.75rem;
				background: var(--panel);
				position: relative;
				overflow: hidden;
				transition: border-color 0.3s, opacity 0.3s;
			}

			.player-card.winner {
				border-color: var(--accent-1);
				animation: heatWave 2s ease-in-out infinite;
			}
			.player-card.loser { opacity: 0.45; }
			.player-card.card-error { border-color: var(--accent-error); }
			.player-card.slide-left { animation: slideInLeft 0.5s ease-out both; }
			.player-card.slide-right { animation: slideInRight 0.5s ease-out both; }
			.player-card.cracked { animation: cardCrack 0.4s ease-out forwards; border-color: var(--accent-error) !important; }
			.player-card.winner-flash { animation: winnerFlash 0.6s ease-out forwards; }

			.player-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 0.3rem;
				padding-bottom: 0.3rem;
				border-bottom: 1px dashed var(--panel-border);
			}

			.player-name {
				font-weight: 700;
				font-size: 0.75rem;
				color: var(--accent-2);
			}

			.player-total {
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--accent-1);
				text-shadow: 0 0 6px rgba(51, 255, 102, 0.4);
			}

			.player-meta {
				color: var(--text-dim);
				font-size: 0.6rem;
				margin-bottom: 0.5rem;
			}

			.player-streak {
				color: var(--accent-2);
				font-size: 0.6rem;
				margin-top: 0.4rem;
			}

			/* ── Contribution Grid ─────────────────────────────────────── */
			.contrib-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				grid-template-rows: repeat(7, 1fr);
				gap: 1px;
				width: 100%;
				aspect-ratio: 53 / 7;
				border: 1px solid var(--panel-border);
				border-radius: 2px;
				padding: 2px;
				background: rgba(0, 0, 0, 0.3);
			}

			.contrib-cell {
				border-radius: 1px;
				position: relative;
				cursor: default;
				transition: box-shadow 0.15s;
			}

			.contrib-cell:hover {
				box-shadow: 0 0 5px currentColor;
				z-index: 2;
			}

			.contrib-cell[data-count]::before {
				content: attr(data-count) " contributions";
				position: absolute;
				bottom: calc(100% + 4px);
				left: 50%;
				transform: translateX(-50%);
				background: #0e0e20;
				color: var(--text);
				padding: 3px 6px;
				border-radius: 2px;
				font-size: 0.55rem;
				white-space: nowrap;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.15s;
				z-index: 10;
				border: 1px solid var(--panel-border);
			}
			.contrib-cell:hover::before { opacity: 1; }

			/* ── Legend ─────────────────────────────────────────────────── */
			.contrib-legend {
				display: flex;
				align-items: center;
				gap: 3px;
				margin-top: 0.4rem;
				font-size: 0.55rem;
				color: var(--text-dim);
			}

			.legend-square {
				width: 9px;
				height: 9px;
				border-radius: 1px;
			}

			/* ── Skeleton ──────────────────────────────────────────────── */
			.skeleton {
				background: linear-gradient(90deg, #0e0e22 25%, #151530 50%, #0e0e22 75%);
				background-size: 200% 100%;
				animation: skeleton-loading 1.5s infinite;
			}

			.skeleton-grid {
				display: grid;
				grid-template-columns: repeat(53, 1fr);
				grid-template-rows: repeat(7, 1fr);
				gap: 1px;
				width: 100%;
				aspect-ratio: 53 / 7;
			}
			.skeleton-cell { background: #0e0e22; border-radius: 1px; }
			.skeleton-text { height: 0.7rem; border-radius: 2px; margin-bottom: 0.4rem; }
			.skeleton-text.short { width: 40%; }
			.skeleton-text.medium { width: 60%; }

			/* ── Winner Banner ─────────────────────────────────────────── */
			#winner-banner {
				text-align: center;
				font-family: var(--font-retro);
				font-size: 0.75rem;
				padding: 0.8rem;
				margin-top: 0.75rem;
				border: 1px solid var(--panel-border);
				border-radius: 4px;
				background: var(--panel);
				animation: bannerPop 0.5s ease-out both;
				color: var(--accent-1);
				text-shadow: 0 0 10px var(--accent-1), 0 0 20px rgba(51, 255, 102, 0.3);
			}

			/* ── Fight Stage ───────────────────────────────────────────── */
			#fight-stage {
				width: 100%;
				height: 160px;
				margin-top: 0.75rem;
				border: 1px solid var(--panel-border);
				border-radius: 4px;
				background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.25) 85%, rgba(26,58,26,0.4) 100%);
				display: block;
			}

			/* ── Battle Canvas ─────────────────────────────────────────── */
			#battle-canvas {
				position: absolute;
				top: 0; left: 0;
				width: 100%; height: 100%;
				z-index: 50;
				pointer-events: none;
			}

			/* ── Countdown ─────────────────────────────────────────────── */
			#countdown-overlay {
				position: fixed;
				inset: 0;
				background: rgba(5, 5, 16, 0.93);
				display: flex;
				align-items: center;
				justify-content: center;
				z-index: 10000;
				font-family: var(--font-retro);
				font-size: 3rem;
				color: var(--accent-1);
				text-shadow: 0 0 20px var(--accent-1), 0 0 60px rgba(51, 255, 102, 0.4);
			}
			.countdown-number { animation: countdownPulse 0.7s ease-out both; }

			/* ── Share Button ──────────────────────────────────────────── */
			#share-btn {
				display: block;
				margin: 0.6rem auto 0;
				padding: 0.35rem 0.8rem;
				border: 1px solid var(--accent-2);
				border-radius: 3px;
				background: transparent;
				color: var(--accent-2);
				font-family: var(--font-term);
				font-size: 0.65rem;
				cursor: pointer;
				transition: background 0.2s, color 0.2s;
			}
			#share-btn:hover { background: var(--accent-2); color: #fff; }

			.copy-confirm {
				text-align: center;
				color: var(--accent-1);
				font-size: 0.6rem;
				margin-top: 0.3rem;
			}

			/* ── Battle History ─────────────────────────────────────────── */
			.history-section {
				margin-top: 1.2rem;
				border-top: 1px solid var(--panel-border);
				padding-top: 0.8rem;
			}

			.history-title {
				font-size: 0.65rem;
				color: var(--accent-2);
				margin: 0 0 0.5rem;
			}

			.history-entry {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.3rem 0.5rem;
				border-left: 2px solid var(--panel-border);
				margin-bottom: 0.2rem;
				font-size: 0.6rem;
				color: var(--text-dim);
				background: rgba(0, 0, 0, 0.2);
			}
			.history-players { color: var(--text); }
			.history-winner { color: var(--accent-1); }

			#clear-history-btn {
				margin-top: 0.4rem;
				padding: 0.2rem 0.5rem;
				border: 1px solid var(--accent-error);
				border-radius: 2px;
				background: transparent;
				color: var(--accent-error);
				font-family: var(--font-term);
				font-size: 0.6rem;
				cursor: pointer;
			}
			#clear-history-btn:hover { background: var(--accent-error); color: #fff; }

			/* ── Utility ───────────────────────────────────────────────── */
			.hidden { display: none !important; }

			/* ── Responsive 1024 ───────────────────────────────────────── */
			@media (max-width: 1024px) {
				.battle-arena { grid-template-columns: 1fr; gap: 0.5rem; }
				.battle-arena .vs-badge { justify-self: center; }
			}

			/* ── Responsive 768 ────────────────────────────────────────── */
			@media (max-width: 768px) {
				body { padding: 0.5rem; }
				.crt-monitor { border-radius: 16px; padding: 16px 16px 10px; }
				.crt-screen { border-radius: 8px / 10px; }
				h1 { font-size: 0.7rem; }
				.input-grid { grid-template-columns: 1fr; gap: 0.5rem; }
				.vs-badge { justify-self: center; width: 36px; height: 36px; font-size: 0.5rem; }
				.container { padding: 1rem; }
				.prompt-line input { font-size: 0.7rem; }
				#battle-btn { font-size: 0.55rem; }
				.player-name { font-size: 0.65rem; }
				.player-total { font-size: 0.7rem; }
				#winner-banner { font-size: 0.55rem; }
				.history-entry { font-size: 0.5rem; }
			}
		</style>
	</head>
	<body>
		<!-- SVG noise filter -->
		<svg style="position:absolute;width:0;height:0" aria-hidden="true">
			<filter id="noiseFilter">
				<feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="4" stitchTiles="stitch" />
			</filter>
		</svg>

		<div class="crt-monitor">
			<div class="crt-screen">
				<div class="crt-scanlines"></div>
				<div class="crt-scanbar"></div>
				<div class="crt-noise"></div>
				<div class="crt-vignette"></div>
				<div class="crt-aberration"></div>
				<div class="crt-glare"></div>
				<div class="screen-content">
					<main class="container">
						<div class="term-header">
							<div class="term-header-left">
								<div class="term-dot red"></div>
								<div class="term-dot yellow"></div>
								<div class="term-dot green"></div>
								<span class="term-title">battle-shell v2.0</span>
							</div>
							<div class="controls">
								<button type="button" class="control-btn" id="theme-toggle">theme:g/p</button>
								<button type="button" class="control-btn" id="mute-toggle">snd:on</button>
							</div>
						</div>

						<div class="title-block">
							<h1>MONA MAYHEM</h1>
							<p class="subtitle">GitHub contribution battle arena</p>
						</div>

						<form id="battle-form">
							<div class="input-grid">
								<div class="input-block">
									<label for="player1">challenger_1</label>
									<div class="prompt-line" id="prompt1">
										<span class="prompt-char">&gt;</span>
										<input id="player1" name="player1" type="text" inputmode="text" spellcheck="false" autocomplete="off" placeholder="github-user-a" />
									</div>
									<div class="error-msg" id="p1-error"></div>
								</div>

								<div class="vs-badge">VS</div>

								<div class="input-block">
									<label for="player2">challenger_2</label>
									<div class="prompt-line" id="prompt2">
										<span class="prompt-char">&gt;</span>
										<input id="player2" name="player2" type="text" inputmode="text" spellcheck="false" autocomplete="off" placeholder="github-user-b" />
									</div>
									<div class="error-msg" id="p2-error"></div>
								</div>
							</div>
							<button id="battle-btn" type="submit">[ execute battle ]</button>
						</form>

						<div id="status" class="hidden"></div>

						<section id="battle-result">
							<canvas id="fight-stage" class="hidden"></canvas>
							<div id="arena" class="hidden"></div>
							<div id="winner-banner" class="hidden"></div>
							<button id="share-btn" class="hidden">$ copy-results</button>
							<div id="copy-confirm" class="copy-confirm hidden"></div>
						</section>

						<section id="battle-history" class="history-section hidden">
							<h2 class="history-title">// recent_battles</h2>
							<div id="history-list"></div>
							<button id="clear-history-btn">$ clear-history</button>
						</section>
					</main>
				</div>
			</div>
			<div class="crt-brand">MONA-MAYHEM<span class="crt-led"></span></div>
		</div>

		<div id="countdown-overlay" class="hidden"></div>

		<script type="module">
			// ── Constants ─────────────────────────────────────────────────
			const USERNAME_RE = /^(?!-)(?!.*--)[a-z0-9](?:[a-z0-9-]{0,37}[a-z0-9])?$/i;
			const DEFAULT_COLORS = ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'];
			const HISTORY_KEY = 'mona-mayhem-history';
			const THEME_KEY = 'mona-mayhem-theme';
			const MUTE_KEY = 'mona-mayhem-mute';
			const MAX_HISTORY = 10;

			// ── DOM ───────────────────────────────────────────────────────
			const form = document.querySelector('#battle-form');
			const button = document.querySelector('#battle-btn');
			const statusEl = document.querySelector('#status');
			const arenaEl = document.querySelector('#arena');
			const bannerEl = document.querySelector('#winner-banner');
			const shareBtn = document.querySelector('#share-btn');
			const copyConfirm = document.querySelector('#copy-confirm');
			const countdownEl = document.querySelector('#countdown-overlay');
			const historySection = document.querySelector('#battle-history');
			const historyList = document.querySelector('#history-list');
			const clearHistoryBtn = document.querySelector('#clear-history-btn');
			const themeToggle = document.querySelector('#theme-toggle');
			const muteToggle = document.querySelector('#mute-toggle');
			const input1 = document.querySelector('#player1');
			const input2 = document.querySelector('#player2');
			const prompt1 = document.querySelector('#prompt1');
			const prompt2 = document.querySelector('#prompt2');
			const error1 = document.querySelector('#p1-error');
			const error2 = document.querySelector('#p2-error');

			// ── Theme ─────────────────────────────────────────────────────
			function applyTheme(t) {
				if (t === 'blue-orange') {
					document.documentElement.setAttribute('data-theme', 'blue-orange');
					themeToggle.textContent = 'theme:b/o';
				} else {
					document.documentElement.removeAttribute('data-theme');
					themeToggle.textContent = 'theme:g/p';
				}
			}
			applyTheme(localStorage.getItem(THEME_KEY) || '');
			themeToggle.addEventListener('click', () => {
				const next = document.documentElement.getAttribute('data-theme') === 'blue-orange' ? '' : 'blue-orange';
				localStorage.setItem(THEME_KEY, next);
				applyTheme(next);
			});

			// ── Sound ─────────────────────────────────────────────────────
			let audioCtx = null;
			let isMuted = localStorage.getItem(MUTE_KEY) === '1';

			function updateMuteUI() { muteToggle.textContent = isMuted ? 'snd:off' : 'snd:on'; }
			updateMuteUI();
			muteToggle.addEventListener('click', () => {
				isMuted = !isMuted;
				localStorage.setItem(MUTE_KEY, isMuted ? '1' : '0');
				updateMuteUI();
			});

			function getAudioCtx() {
				if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
				if (audioCtx.state === 'suspended') audioCtx.resume();
				return audioCtx;
			}

			function playCoinSound() {
				if (isMuted) return;
				const ctx = getAudioCtx(); const now = ctx.currentTime;
				[440, 880].forEach((f, i) => {
					const o = ctx.createOscillator(), g = ctx.createGain();
					o.type = 'square'; o.frequency.value = f;
					g.gain.setValueAtTime(0.12, now + i * 0.1);
					g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.1 + 0.15);
					o.connect(g).connect(ctx.destination);
					o.start(now + i * 0.1); o.stop(now + i * 0.1 + 0.15);
				});
			}

			function playPowerUpSound() {
				if (isMuted) return;
				const ctx = getAudioCtx(); const now = ctx.currentTime;
				[523, 659, 784, 1047].forEach((f, i) => {
					const o = ctx.createOscillator(), g = ctx.createGain();
					o.type = 'square'; o.frequency.value = f;
					g.gain.setValueAtTime(0.1, now + i * 0.08);
					g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.08 + 0.2);
					o.connect(g).connect(ctx.destination);
					o.start(now + i * 0.08); o.stop(now + i * 0.08 + 0.2);
				});
			}

			function playErrorSound() {
				if (isMuted) return;
				const ctx = getAudioCtx(); const now = ctx.currentTime;
				[300, 200].forEach((f, i) => {
					const o = ctx.createOscillator(), g = ctx.createGain();
					o.type = 'sawtooth'; o.frequency.value = f;
					g.gain.setValueAtTime(0.12, now + i * 0.15);
					g.gain.exponentialRampToValueAtTime(0.001, now + i * 0.15 + 0.25);
					o.connect(g).connect(ctx.destination);
					o.start(now + i * 0.15); o.stop(now + i * 0.15 + 0.25);
				});
			}

			function playImpactSound() {
				if (isMuted) return;
				const ctx = getAudioCtx(); const now = ctx.currentTime;
				const o = ctx.createOscillator(), g = ctx.createGain();
				o.type = 'square';
				o.frequency.setValueAtTime(150, now);
				o.frequency.exponentialRampToValueAtTime(40, now + 0.15);
				g.gain.setValueAtTime(0.15, now);
				g.gain.exponentialRampToValueAtTime(0.001, now + 0.2);
				o.connect(g).connect(ctx.destination);
				o.start(now); o.stop(now + 0.2);
			}

			// ── Typewriter Status Log ─────────────────────────────────────
			let typewriterQueue = [];
			let typewriterRunning = false;

			function logStatus(text) {
				return new Promise((resolve) => {
					typewriterQueue.push({ text, resolve });
					if (!typewriterRunning) drainQueue();
				});
			}

			async function drainQueue() {
				typewriterRunning = true;
				while (typewriterQueue.length > 0) {
					const { text, resolve } = typewriterQueue.shift();
					await typewriteLine(text);
					resolve();
				}
				typewriterRunning = false;
			}

			function typewriteLine(text) {
				return new Promise((resolve) => {
					statusEl.classList.remove('hidden');
					const line = document.createElement('span');
					line.className = 'log-line';
					statusEl.appendChild(line);

					const cursor = document.createElement('span');
					cursor.className = 'cursor-blink';
					line.appendChild(cursor);

					let i = 0;
					const speed = Math.max(12, 400 / text.length);
					function tick() {
						if (i < text.length) {
							line.insertBefore(document.createTextNode(text[i]), cursor);
							i++;
							setTimeout(tick, speed);
						} else {
							cursor.remove();
							resolve();
						}
					}
					tick();
				});
			}

			function clearLog() {
				statusEl.innerHTML = '';
				statusEl.classList.add('hidden');
				typewriterQueue = [];
			}

			// ── Countdown ─────────────────────────────────────────────────
			function playCountdown() {
				return new Promise((resolve) => {
					const steps = ['3', '2', '1', 'FIGHT!'];
					let i = 0;
					countdownEl.classList.remove('hidden');
					function showNext() {
						if (i >= steps.length) {
							countdownEl.classList.add('hidden');
							countdownEl.innerHTML = '';
							resolve(); return;
						}
						const col = i === 3 ? 'var(--accent-2)' : 'var(--accent-1)';
						countdownEl.innerHTML = `<span class="countdown-number" style="color:${col}">${steps[i]}</span>`;
						i++;
						setTimeout(showNext, i <= 3 ? 700 : 500);
					}
					showNext();
				});
			}

			// ── Validation ────────────────────────────────────────────────
			function isValidUsername(n) { return Boolean(n) && n.length <= 39 && USERNAME_RE.test(n); }
			function normalize(n) { return (n || '').trim().toLowerCase(); }

			function showError(promptEl, errorEl, msg) {
				promptEl.classList.add('input-error');
				errorEl.textContent = '> ERR: ' + msg;
			}
			function clearError(promptEl, errorEl) {
				promptEl.classList.remove('input-error');
				errorEl.textContent = '';
			}
			input1.addEventListener('input', () => clearError(prompt1, error1));
			input2.addEventListener('input', () => clearError(prompt2, error2));

			// ── API ───────────────────────────────────────────────────────
			async function fetchPlayer(username) {
				const res = await fetch(`/api/contributions/${encodeURIComponent(username)}`);
				const payload = await res.json();
				if (!res.ok) throw new Error(payload?.error?.message || `HTTP ${res.status}`);
				const d = payload.data;
				return {
					username,
					total: d.total_contributions || 0,
					from: d.from || '', to: d.to || '',
					colors: d.colors_full || DEFAULT_COLORS,
					weeks: d.weeks || [],
				};
			}

			// ── Streak ────────────────────────────────────────────────────
			function computeStreak(weeks) {
				if (!weeks?.length) return 0;
				let max = 0, cur = 0;
				for (const w of weeks) for (const d of w.contribution_days) {
					if (d.count > 0) { cur++; if (cur > max) max = cur; }
					else cur = 0;
				}
				return max;
			}

			// ── Rendering ─────────────────────────────────────────────────
			function fmtDate(s) {
				if (!s) return '';
				return new Date(s).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
			}

			function renderGrid(p) {
				if (!p.weeks?.length) return '';
				const cells = p.weeks.flatMap(w =>
					w.contribution_days.map(d => {
						const c = p.colors[d.level] || p.colors[0];
						return `<div class="contrib-cell" style="background:${c};color:${c}" data-count="${d.count}"></div>`;
					})
				).join('');
				return `<div class="contrib-grid">${cells}</div>`;
			}

			function renderLegend(colors) {
				if (!colors?.length) return '';
				return `<div class="contrib-legend"><span>Less</span>${colors.map(c => `<div class="legend-square" style="background:${c}"></div>`).join('')}<span>More</span></div>`;
			}

			function renderPlayerCard(player, status, slide) {
				const cls = ['player-card', status, slide].filter(Boolean).join(' ');
				if (player.error) {
					return `<div class="${cls} card-error">
						<div class="player-header"><span class="player-name">${player.username}</span></div>
						<div class="error-msg">> ERR: ${player.errorMessage || 'connection failed'}</div>
					</div>`;
				}
				const dateRange = player.from && player.to ? `${fmtDate(player.from)} - ${fmtDate(player.to)}` : '';
				const streak = computeStreak(player.weeks);
				return `<div class="${cls}">
					<div class="player-header">
						<span class="player-name">${player.username}</span>
						<span class="player-total">${player.total.toLocaleString()}</span>
					</div>
					<div class="player-meta">${dateRange}</div>
					${renderGrid(player)}
					${renderLegend(player.colors)}
					<div class="player-streak">streak: ${streak} days</div>
				</div>`;
			}

			function renderSkeleton() {
				const cells = Array(371).fill('<div class="skeleton-cell skeleton"></div>').join('');
				const card = `<div class="player-card"><div class="skeleton skeleton-text short"></div><div class="skeleton skeleton-text medium"></div><div class="skeleton-grid">${cells}</div></div>`;
				arenaEl.innerHTML = `<div class="battle-arena">${card}<div class="vs-badge">VS</div>${card}</div>`;
				arenaEl.classList.remove('hidden');
			}

			function render(players) {
				const [p1, p2] = players;
				const ok = !p1.error && !p2.error;
				let s1 = null, s2 = null;
				if (ok) {
					if (p1.total > p2.total) { s1 = 'winner'; s2 = 'loser'; }
					else if (p2.total > p1.total) { s1 = 'loser'; s2 = 'winner'; }
				}
				arenaEl.innerHTML = `<div class="battle-arena">
					${renderPlayerCard(p1, s1, 'slide-left')}
					<div class="vs-badge">VS</div>
					${renderPlayerCard(p2, s2, 'slide-right')}
				</div>`;
				arenaEl.classList.remove('hidden');
			}

			function renderBanner(players) {
				const valid = players.filter(p => !p.error);
				bannerEl.classList.remove('hidden');
				if (valid.length < 2) {
					bannerEl.textContent = valid.length === 1 ? `${valid[0].username} wins by default` : 'both players failed';
					return;
				}
				const [a, b] = valid;
				if (a.total === b.total) bannerEl.textContent = `TIE! ${a.total.toLocaleString()} each`;
				else {
					const w = a.total > b.total ? a : b;
					bannerEl.textContent = `${w.username} WINS!`;
				}
			}

			// ── Stick Figure System ───────────────────────────────────────
			const stageCanvas = document.querySelector('#fight-stage');
			const sCtx = stageCanvas.getContext('2d');
			let figureL = null, figureR = null;
			let stageAnimId = null;

			class StickFigure {
				constructor(baseX, groundY, color, facing) {
					this.baseX = baseX;
					this.groundY = groundY;
					this.color = color;
					this.facing = facing;
					this.hp = 100;
					this.state = 'idle';
					this.phase = Math.random() * 6.28;
					this.knockX = 0;
					this.knockVX = 0;
					this.hitFlash = 0;

					const f = facing;
					this.joints = {
						head:   this.j(0, -62),
						neck:   this.j(0, -50),
						body:   this.j(0, -30),
						hip:    this.j(0, -12),
						lElbow: this.j(-14 * f, -42),
						rElbow: this.j(14 * f, -42),
						lHand:  this.j(-22 * f, -30),
						rHand:  this.j(22 * f, -30),
						lKnee:  this.j(-7, 2),
						rKnee:  this.j(7, 2),
						lFoot:  this.j(-11, 16),
						rFoot:  this.j(11, 16),
					};

					// Store original targets
					for (const jt of Object.values(this.joints)) {
						jt.ox = jt.tx; jt.oy = jt.ty;
					}
				}

				j(x, y) { return { x, y, tx: x, ty: y, vx: 0, vy: 0 }; }

				applyHit(force) {
					this.hp = Math.max(0, this.hp - 12);
					this.hitFlash = 8;
					this.knockVX += force * 0.8;
					const isKO = this.hp <= 0;
					if (isKO) this.state = 'ko';
					else this.state = 'hit';

					for (const jt of Object.values(this.joints)) {
						jt.vx += force * (0.6 + Math.random() * 0.8);
						jt.vy += (Math.random() - 0.4) * Math.abs(force) * 0.6;
					}
				}

				setVictory() { this.state = 'victory'; }

				update() {
					this.phase += 0.06;
					if (this.hitFlash > 0) this.hitFlash--;

					// Knockback recovery
					this.knockVX *= 0.88;
					this.knockX += this.knockVX;
					this.knockX *= 0.92;

					const f = this.facing;

					// Update idle pose targets based on state
					if (this.state === 'idle') {
						const bob = Math.sin(this.phase) * 2;
						const armSwing = Math.sin(this.phase * 0.7) * 5;
						this.joints.head.ty = -62 + bob;
						this.joints.neck.ty = -50 + bob * 0.8;
						this.joints.body.ty = -30 + bob * 0.4;
						this.joints.lHand.tx = -22 * f + armSwing;
						this.joints.rHand.tx = 22 * f - armSwing;
						this.joints.lElbow.tx = -14 * f + armSwing * 0.5;
						this.joints.rElbow.tx = 14 * f - armSwing * 0.5;
					} else if (this.state === 'victory') {
						const jump = Math.abs(Math.sin(this.phase * 1.5)) * 12;
						this.joints.head.ty = -62 - jump - 5;
						this.joints.neck.ty = -50 - jump - 3;
						this.joints.body.ty = -30 - jump;
						this.joints.hip.ty = -12 - jump;
						this.joints.lElbow.ty = -55 - jump;
						this.joints.rElbow.ty = -55 - jump;
						this.joints.lHand.ty = -62 - jump;
						this.joints.rHand.ty = -62 - jump;
						this.joints.lHand.tx = -18 * f;
						this.joints.rHand.tx = 18 * f;
						this.joints.lKnee.ty = 2 - jump * 0.5;
						this.joints.rKnee.ty = 2 - jump * 0.5;
						this.joints.lFoot.ty = 16 - jump * 0.2;
						this.joints.rFoot.ty = 16 - jump * 0.2;
					} else if (this.state === 'ko') {
						// Collapse — targets shift to lying down
						const lean = this.facing * 30;
						this.joints.head.tx = lean + 20 * this.facing;
						this.joints.head.ty = 10;
						this.joints.neck.tx = lean + 10 * this.facing;
						this.joints.neck.ty = 5;
						this.joints.body.tx = lean;
						this.joints.body.ty = 8;
						this.joints.hip.tx = lean - 5 * this.facing;
						this.joints.hip.ty = 12;
						this.joints.lElbow.tx = lean + 25 * this.facing;
						this.joints.lElbow.ty = 12;
						this.joints.rElbow.tx = lean - 10 * this.facing;
						this.joints.rElbow.ty = 14;
						this.joints.lHand.tx = lean + 35 * this.facing;
						this.joints.lHand.ty = 15;
						this.joints.rHand.tx = lean - 15 * this.facing;
						this.joints.rHand.ty = 16;
						this.joints.lKnee.tx = lean - 12 * this.facing;
						this.joints.lKnee.ty = 14;
						this.joints.rKnee.tx = lean - 18 * this.facing;
						this.joints.rKnee.ty = 12;
						this.joints.lFoot.tx = lean - 20 * this.facing;
						this.joints.lFoot.ty = 16;
						this.joints.rFoot.tx = lean - 28 * this.facing;
						this.joints.rFoot.ty = 14;
					}

					// Spring physics
					const spring = this.state === 'ko' ? 0.06 : (this.state === 'hit' ? 0.08 : 0.12);
					const damp = this.state === 'ko' ? 0.82 : 0.86;

					for (const jt of Object.values(this.joints)) {
						jt.vx += (jt.tx - jt.x) * spring;
						jt.vy += (jt.ty - jt.y) * spring;
						if (this.state === 'ko') jt.vy += 0.15;
						jt.vx *= damp;
						jt.vy *= damp;
						jt.x += jt.vx;
						jt.y += jt.vy;
						// Ground constraint
						if (jt.y > 18) { jt.y = 18; jt.vy *= -0.2; }
					}

					// Recover from hit
					if (this.state === 'hit' && this.hitFlash === 0) this.state = 'idle';
				}

				draw(ctx) {
					const bx = this.baseX + this.knockX;
					const by = this.groundY;
					const j = this.joints;

					// Hit flash
					const col = this.hitFlash > 0 && this.hitFlash % 2 === 0 ? '#fff' : this.color;

					ctx.strokeStyle = col;
					ctx.fillStyle = col;
					ctx.lineWidth = 3;
					ctx.lineCap = 'round';
					ctx.lineJoin = 'round';
					ctx.shadowColor = col;
					ctx.shadowBlur = this.state === 'victory' ? 12 : 5;

					// Head
					ctx.beginPath();
					ctx.arc(bx + j.head.x, by + j.head.y, 7, 0, Math.PI * 2);
					ctx.stroke();

					// Eyes (simple dots)
					if (this.state !== 'ko') {
						ctx.fillStyle = col;
						const eyeX = this.facing * 2.5;
						ctx.fillRect(bx + j.head.x + eyeX - 1, by + j.head.y - 2, 2, 2);
						ctx.fillRect(bx + j.head.x + eyeX + 4 * this.facing, by + j.head.y - 2, 2, 2);
					} else {
						// X eyes for KO
						ctx.lineWidth = 1.5;
						const hx = bx + j.head.x, hy = by + j.head.y;
						ctx.beginPath(); ctx.moveTo(hx - 3, hy - 4); ctx.lineTo(hx + 1, hy); ctx.stroke();
						ctx.beginPath(); ctx.moveTo(hx + 1, hy - 4); ctx.lineTo(hx - 3, hy); ctx.stroke();
						ctx.beginPath(); ctx.moveTo(hx + 3, hy - 4); ctx.lineTo(hx + 7, hy); ctx.stroke();
						ctx.beginPath(); ctx.moveTo(hx + 7, hy - 4); ctx.lineTo(hx + 3, hy); ctx.stroke();
						ctx.lineWidth = 3;
					}

					// Body (neck → body → hip)
					this.drawLimb(ctx, bx, by, j.neck, j.body);
					this.drawLimb(ctx, bx, by, j.body, j.hip);

					// Arms
					this.drawLimb(ctx, bx, by, j.neck, j.lElbow);
					this.drawLimb(ctx, bx, by, j.lElbow, j.lHand);
					this.drawLimb(ctx, bx, by, j.neck, j.rElbow);
					this.drawLimb(ctx, bx, by, j.rElbow, j.rHand);

					// Legs
					this.drawLimb(ctx, bx, by, j.hip, j.lKnee);
					this.drawLimb(ctx, bx, by, j.lKnee, j.lFoot);
					this.drawLimb(ctx, bx, by, j.hip, j.rKnee);
					this.drawLimb(ctx, bx, by, j.rKnee, j.rFoot);

					ctx.shadowBlur = 0;
				}

				drawLimb(ctx, bx, by, a, b) {
					ctx.beginPath();
					ctx.moveTo(bx + a.x, by + a.y);
					ctx.lineTo(bx + b.x, by + b.y);
					ctx.stroke();
				}
			}

			function initFighters(color1, color2) {
				// Must unhide BEFORE measuring dimensions
				stageCanvas.classList.remove('hidden');

				const dpr = window.devicePixelRatio || 1;
				const rect = stageCanvas.getBoundingClientRect();
				stageCanvas.width = rect.width * dpr;
				stageCanvas.height = rect.height * dpr;
				stageCanvas.style.width = rect.width + 'px';
				stageCanvas.style.height = rect.height + 'px';
				sCtx.setTransform(dpr, 0, 0, dpr, 0, 0);

				const W = rect.width, H = rect.height;
				const groundY = H - 20;

				figureL = new StickFigure(W * 0.2, groundY, color1, 1);
				figureR = new StickFigure(W * 0.8, groundY, color2, -1);

				// Ground line
				function drawGround() {
					sCtx.strokeStyle = 'rgba(26, 58, 26, 0.5)';
					sCtx.lineWidth = 1;
					sCtx.setLineDash([4, 4]);
					sCtx.beginPath();
					sCtx.moveTo(0, groundY + 18);
					sCtx.lineTo(W, groundY + 18);
					sCtx.stroke();
					sCtx.setLineDash([]);
				}

				if (stageAnimId) cancelAnimationFrame(stageAnimId);
				function loop() {
					sCtx.clearRect(0, 0, W, H);
					drawGround();
					figureL.update(); figureL.draw(sCtx);
					figureR.update(); figureR.draw(sCtx);

					// Name labels
					sCtx.font = '10px "Share Tech Mono", monospace';
					sCtx.textAlign = 'center';
					sCtx.fillStyle = figureL.color;
					sCtx.shadowColor = figureL.color;
					sCtx.shadowBlur = 4;
					sCtx.fillText(figureL.label || '', figureL.baseX + figureL.knockX, groundY + 34);
					sCtx.fillStyle = figureR.color;
					sCtx.shadowColor = figureR.color;
					sCtx.fillText(figureR.label || '', figureR.baseX + figureR.knockX, groundY + 34);
					sCtx.shadowBlur = 0;

					stageAnimId = requestAnimationFrame(loop);
				}
				loop();
			}

			function stopFighters() {
				if (stageAnimId) { cancelAnimationFrame(stageAnimId); stageAnimId = null; }
			}

			// ── Battle Canvas Animation ───────────────────────────────────
			const battleCanvas = document.querySelector('#battle-canvas');
			const bCtx = battleCanvas.getContext('2d');

			function sampleArray(arr, max) {
				if (arr.length <= max) return [...arr];
				const step = arr.length / max;
				return Array.from({ length: max }, (_, i) => arr[Math.floor(i * step)]);
			}

			function runBattleAnimation(players) {
				return new Promise((resolve) => {
					const [p1, p2] = players;
					if (p1.error || p2.error) { resolve(); return; }

					const section = document.querySelector('#battle-result');
					const rect = section.getBoundingClientRect();
					const dpr = window.devicePixelRatio || 1;
					battleCanvas.width = rect.width * dpr;
					battleCanvas.height = rect.height * dpr;
					battleCanvas.style.width = rect.width + 'px';
					battleCanvas.style.height = rect.height + 'px';
					bCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
					battleCanvas.classList.remove('hidden');

					const W = rect.width, H = rect.height;
					const gather = (p) => {
						const days = [];
						for (const w of p.weeks) for (const d of w.contribution_days) if (d.count > 0) days.push(d);
						return days;
					};
					const d1 = sampleArray(gather(p1), 40);
					const d2 = sampleArray(gather(p2), 40);

					const projs = [], parts = [];
					let frame = 0, i1 = 0, i2 = 0, resolved = false;
					const rate = 2;
					const winSide = p1.total >= p2.total ? 'left' : 'right';

					function spawn(day, side, colors) {
						const c = colors[Math.min(day.level, colors.length - 1)] || '#33ff66';
						const r = 2.5 + day.level * 1.8;
						const spd = 3.5 + day.level * 1;
						return { x: side === 'left' ? -r : W + r, y: 25 + Math.random() * (H - 50),
							vx: side === 'left' ? spd : -spd, vy: (Math.random() - 0.5) * 1.8,
							radius: r, color: c, side, alive: true, trail: [] };
					}

					function explode(x, y, c, n) {
						for (let i = 0; i < n; i++) {
							const a = Math.random() * Math.PI * 2, s = 1 + Math.random() * 3.5;
							parts.push({ x, y, vx: Math.cos(a) * s, vy: Math.sin(a) * s,
								radius: 1 + Math.random() * 2, color: c, alpha: 1, life: 22 + Math.random() * 20, maxLife: 45 });
						}
					}

					function tick() {
						bCtx.clearRect(0, 0, W, H);

						if (frame % rate === 0) {
							if (i1 < d1.length) projs.push(spawn(d1[i1++], 'left', p1.colors));
							if (i2 < d2.length) projs.push(spawn(d2[i2++], 'right', p2.colors));
						}

						for (const p of projs) {
							if (!p.alive) continue;
							p.trail.push({ x: p.x, y: p.y });
							if (p.trail.length > 5) p.trail.shift();
							p.x += p.vx; p.y += p.vy; p.vy *= 0.99;

							for (const o of projs) {
								if (!o.alive || o.side === p.side) continue;
								const dx = p.x - o.x, dy = p.y - o.y;
								if (Math.sqrt(dx * dx + dy * dy) < p.radius + o.radius + 2) {
									const cx = (p.x + o.x) / 2, cy = (p.y + o.y) / 2;
									explode(cx, cy, p.color, 5);
									explode(cx, cy, o.color, 5);
									p.alive = false; o.alive = false;
									playImpactSound();
									break;
								}
							}

							// Hit stick figures when projectiles reach opposing edge
							if (p.alive) {
								if (p.side === 'left' && p.x > W * 0.75) {
									if (figureR) figureR.applyHit(8);
									explode(p.x, p.y, p.color, 4);
									p.alive = false;
									playImpactSound();
								} else if (p.side === 'right' && p.x < W * 0.25) {
									if (figureL) figureL.applyHit(-8);
									explode(p.x, p.y, p.color, 4);
									p.alive = false;
									playImpactSound();
								} else if (p.x < -20 || p.x > W + 20 || p.y < -20 || p.y > H + 20) {
									p.alive = false;
								}
							}

							if (p.alive) {
								for (let t = 0; t < p.trail.length; t++) {
									bCtx.globalAlpha = (t / p.trail.length) * 0.25;
									bCtx.beginPath();
									bCtx.arc(p.trail[t].x, p.trail[t].y, p.radius * 0.5, 0, Math.PI * 2);
									bCtx.fillStyle = p.color;
									bCtx.fill();
								}
								bCtx.globalAlpha = 1;
								bCtx.beginPath();
								bCtx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
								bCtx.fillStyle = p.color;
								bCtx.shadowColor = p.color;
								bCtx.shadowBlur = 10;
								bCtx.fill();
								bCtx.shadowBlur = 0;
							}
						}

						for (let i = parts.length - 1; i >= 0; i--) {
							const pt = parts[i];
							pt.x += pt.vx; pt.y += pt.vy;
							pt.vx *= 0.95; pt.vy *= 0.95;
							pt.life--; pt.alpha = Math.max(0, pt.life / pt.maxLife);
							if (pt.life <= 0) { parts.splice(i, 1); continue; }
							bCtx.globalAlpha = pt.alpha;
							bCtx.beginPath();
							bCtx.arc(pt.x, pt.y, pt.radius, 0, Math.PI * 2);
							bCtx.fillStyle = pt.color;
							bCtx.shadowColor = pt.color;
							bCtx.shadowBlur = 5;
							bCtx.fill();
							bCtx.shadowBlur = 0;
						}
						bCtx.globalAlpha = 1;

						frame++;
						const done = i1 >= d1.length && i2 >= d2.length;
						const alive = projs.filter(p => p.alive).length;

						if ((done && alive === 0 && parts.length === 0) || frame > 300) {
							if (!resolved) {
								resolved = true;
								const cards = arenaEl.querySelectorAll('.player-card');
								if (cards.length === 2 && p1.total !== p2.total) {
									const li = winSide === 'left' ? 1 : 0, wi = winSide === 'left' ? 0 : 1;
									cards[li].classList.add('cracked');
									cards[wi].classList.add('winner-flash');
									// Final stick figure states
									const winFig = winSide === 'left' ? figureL : figureR;
									const loseFig = winSide === 'left' ? figureR : figureL;
									if (winFig) winFig.setVictory();
									if (loseFig) { loseFig.hp = 0; loseFig.state = 'ko'; }
								}
								setTimeout(() => {
									battleCanvas.classList.add('hidden');
									bCtx.setTransform(1, 0, 0, 1, 0, 0);
									resolve();
								}, 350);
							}
							return;
						}
						requestAnimationFrame(tick);
					}
					requestAnimationFrame(tick);
				});
			}

			// ── History ───────────────────────────────────────────────────
			function getHistory() { try { return JSON.parse(localStorage.getItem(HISTORY_KEY)) || []; } catch { return []; } }
			function saveHistory(e) {
				const h = getHistory(); h.unshift(e);
				if (h.length > MAX_HISTORY) h.length = MAX_HISTORY;
				localStorage.setItem(HISTORY_KEY, JSON.stringify(h));
			}
			function renderHistory() {
				const h = getHistory();
				if (!h.length) { historySection.classList.add('hidden'); return; }
				historySection.classList.remove('hidden');
				historyList.innerHTML = h.map(e => {
					const t = new Date(e.time).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
					return `<div class="history-entry"><span class="history-players">${e.p1.name} (${e.p1.total}) vs ${e.p2.name} (${e.p2.total})</span><span class="history-winner">${e.winner}</span><span>${t}</span></div>`;
				}).join('');
			}
			clearHistoryBtn.addEventListener('click', () => { localStorage.removeItem(HISTORY_KEY); renderHistory(); });
			renderHistory();

			// ── Share ─────────────────────────────────────────────────────
			let lastPlayers = null;
			shareBtn.addEventListener('click', async () => {
				if (!lastPlayers) return;
				const [a, b] = lastPlayers;
				let txt = `MONA MAYHEM BATTLE RESULTS\n${a.username}: ${a.total.toLocaleString()} contributions\n${b.username}: ${b.total.toLocaleString()} contributions\n`;
				if (a.error || b.error) txt += 'Result: incomplete';
				else if (a.total === b.total) txt += 'Result: TIE!';
				else txt += `Winner: ${(a.total > b.total ? a : b).username}!`;
				try {
					await navigator.clipboard.writeText(txt);
					copyConfirm.textContent = '> copied to clipboard';
					copyConfirm.classList.remove('hidden');
					setTimeout(() => copyConfirm.classList.add('hidden'), 2000);
				} catch {
					copyConfirm.textContent = '> copy failed';
					copyConfirm.classList.remove('hidden');
					setTimeout(() => copyConfirm.classList.add('hidden'), 2000);
				}
			});

			// ── Main Battle ───────────────────────────────────────────────
			async function handleBattle() {
				clearError(prompt1, error1);
				clearError(prompt2, error2);
				bannerEl.classList.add('hidden');
				shareBtn.classList.add('hidden');
				copyConfirm.classList.add('hidden');
				clearLog();

				const p1 = normalize(input1.value);
				const p2 = normalize(input2.value);
				let err = false;

				if (!p1 || !isValidUsername(p1)) { showError(prompt1, error1, p1 ? 'invalid username' : 'username required'); err = true; }
				if (!p2 || !isValidUsername(p2)) { showError(prompt2, error2, p2 ? 'invalid username' : 'username required'); err = true; }

				if (err) {
					playErrorSound();
					form.classList.add('shake');
					setTimeout(() => form.classList.remove('shake'), 400);
					return;
				}

				playCoinSound();
				button.disabled = true;
				button.textContent = '[ executing... ]';

				await logStatus(`initializing battle: ${p1} vs ${p2}`);
				logStatus('fetching contribution data...');

				renderSkeleton();

				const [, results] = await Promise.all([
					playCountdown(),
					Promise.allSettled([fetchPlayer(p1), fetchPlayer(p2)])
				]);

				const players = results.map((r, i) => {
					if (r.status === 'fulfilled') return r.value;
					return { username: [p1, p2][i], total: 0, from: '', to: '', colors: DEFAULT_COLORS, weeks: [],
						error: true, errorMessage: r.reason?.message || 'connection failed' };
				});

				lastPlayers = players;

				await logStatus('data received. rendering combat zone...');
				render(players);

				// Init stick fighters
				const bothOk = !players[0].error && !players[1].error;
				if (bothOk) {
					const c1 = players[0].colors[3] || '#33ff66';
					const c2 = players[1].colors[3] || '#a855f7';
					initFighters(c1, c2);
					figureL.label = players[0].username;
					figureR.label = players[1].username;
				}

				await logStatus('initiating commit cannon sequence...');
				await runBattleAnimation(players);

				const anyErr = players.some(p => p.error);
				if (anyErr) {
					playErrorSound();
					await logStatus('WARNING: one or more connections failed');
				} else {
					playPowerUpSound();
					const valid = players.filter(p => !p.error);
					if (valid.length === 2) {
						const [a, b] = valid;
						if (a.total === b.total) await logStatus(`result: TIE at ${a.total.toLocaleString()} contributions`);
						else {
							const w = a.total > b.total ? a : b;
							await logStatus(`result: ${w.username} wins with ${w.total.toLocaleString()} contributions`);
						}
					}
				}

				renderBanner(players);

				const valid = players.filter(p => !p.error);
				if (valid.length === 2) {
					const winner = valid[0].total > valid[1].total ? valid[0].username
						: valid[1].total > valid[0].total ? valid[1].username : 'Tie';
					saveHistory({ p1: { name: valid[0].username, total: valid[0].total },
						p2: { name: valid[1].username, total: valid[1].total }, winner, time: Date.now() });
					renderHistory();
				}

				shareBtn.classList.remove('hidden');
				button.disabled = false;
				button.textContent = '[ execute battle ]';
			}

			form.addEventListener('submit', (e) => { e.preventDefault(); handleBattle(); });
		</script>
	</body>
</html>
